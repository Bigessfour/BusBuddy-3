{
  "SyncfusionLicenseKey": "${SYNCFUSION_LICENSE_KEY}",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=localhost\\SQLEXPRESS;Initial Catalog=BusBuddy;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True",
    "LocalConnection": "Data Source=localhost\\SQLEXPRESS;Initial Catalog=BusBuddy;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True",
    "PostgresConnection": "Host=localhost;Port=5432;Database=busbuddy_test;Username=busbuddy;Password=${BUSBUDDY_PG_PASSWORD}",
    "BusBuddyDatabase": "Data Source=BusBuddy.db"
  },
  "GoogleEarthEngine": {
    "ProjectId": "ee-bigessfour",
    "ServiceAccountEmail": "bus-buddy-gee@ee-bigessfour.iam.gserviceaccount.com",
    "ServiceAccountKeyPath": "keys/bus-buddy-gee-key.json",
    "BaseUrl": "https://earthengine.googleapis.com/v1alpha",
    "CodeEditorUrl": "https://code.earthengine.google.com/",
    "TimeoutSeconds": 30,
    "RetryAttempts": 3,
    "CacheExpiryHours": 1,
    "MaxConcurrentRequests": 5,
    "EnableSatelliteImagery": false,
    "EnableTerrainAnalysis": false,
    "EnableTrafficAnalysis": false,
    "EnableWeatherAnalysis": false,
    "DefaultImageResolution": 30,
    "MaxRouteLength": 100000,
    "ServiceArea": {
      "Name": "Bus Buddy Service Area",
      "MinLatitude": 33.0,
      "MaxLatitude": 34.0,
      "MinLongitude": -113.0,
      "MaxLongitude": -111.0
    }
  },
  "XAI": {
    "ApiKey": "${XAI_API_KEY}",
    "BaseUrl": "https://api.x.ai/v1",
    "DefaultModel": "grok-4-latest",
    "TimeoutSeconds": 60,
    "RetryAttempts": 3,
    "MaxTokens": 128000,
    "Temperature": 0.3,
    "UseLiveAPI": false,
    "EnableRouteOptimization": false,
    "EnableMaintenancePrediction": false,
    "EnableSafetyAnalysis": false,
    "EnableStudentOptimization": false,
    "EnableConversationalAI": false,
    "CacheAIResponses": false,
    "CacheExpiryHours": 24,
    "RateLimitPerMinute": 60,
    "PriorityLevel": "Standard",
    "Documentation": {
      "BaseUrl": "https://docs.x.ai",
      "OverviewGuide": "/docs/overview",
      "ChatGuide": "/docs/guides/chat",
      "ApiReference": "/docs/api-reference",
      "ModelsGuide": "/docs/models",
      "AuthenticationGuide": "/docs/authentication",
      "RateLimitsGuide": "/docs/rate-limits",
      "LastUpdated": "2025-07-04",
      "Version": "v1"
    },
    "SystemPrompts": {
      "Transportation": "You are an expert transportation optimization specialist...",
      "Maintenance": "You are a certified fleet maintenance expert...",
      "Safety": "You are a school transportation safety specialist...",
      "Logistics": "You are a logistics optimization expert..."
    }
  },
  "DatabaseProvider": "Azure",
  "AppSettings": {
    "Theme": "FluentDark",
    "AutoSave": true,
    "AutoSaveInterval": 300,
    "MaxRecentFiles": 10,
    "EnableDetailedLogging": true,
    "AutoMigrateDatabase": true,
    "DefaultPageSize": 25,
    "MaxSearchResults": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Debug",
      "BusBuddy.Core.Services.BusService": "Debug",
      "BusBuddy.Core.Services.BusCachingService": "Debug",
      "System": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread",
      "Serilog.Enrichers.Process"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Debug",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "BusBuddy.WPF.Views.Dashboard.DashboardView": "Debug",
        "BusBuddy.WPF.Views.Main.MainWindow": "Debug",
        "BusBuddy.WPF.Views.Student.StudentsView": "Debug",
        "BusBuddy.WPF.ViewModels.Student.StudentsViewModel": "Debug",
        "BusBuddy.WPF.Views.Dashboard.DashboardWelcomeView": "Debug",
        "BusBuddy.WPF.ViewModels.Dashboard.DashboardViewModel": "Debug",
        "BusBuddy.WPF.ViewModels.Dashboard.DashboardAnalyticsViewModel": "Debug",
        "BusBuddy.WPF.ViewModels.MainWindowViewModel": "Debug",
        "BusBuddy.WPF.Views.Driver.DriversView": "Debug",
        "BusBuddy.WPF.Views.Driver.DriverManagementView": "Debug",
        "BusBuddy.WPF.Views.Driver.DriverForm": "Debug",
        "BusBuddy.WPF.ViewModels.Driver.DriversViewModel": "Debug",
        "BusBuddy.WPF.ViewModels.Driver.DriverFormViewModel": "Debug",
        "BusBuddy.WPF.Views.Route.RouteManagementView": "Debug",
        "BusBuddy.WPF.Views.Route.RouteAssignmentView": "Debug",
        "BusBuddy.WPF.ViewModels.Route.RouteManagementViewModel": "Debug",
        "BusBuddy.WPF.ViewModels.Route.RouteAssignmentViewModel": "Debug",
        "BusBuddy.Core.Services": "Debug",
        "BusBuddy.Core.Data": "Information",
        "System.Windows": "Error"
      }
    },
    "Enrich": [
      "WithMachineName",
      "WithThreadId",
      "WithProcessId",
      "FromLogContext"
    ],
    "Properties": {
      "Application": "BusBuddy.WPF",
      "Environment": "${ASPNETCORE_ENVIRONMENT:Production}"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] \ud83d\ude8c {Message:lj}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Information"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "..\\logs\\log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "shared": true,
          "fileSizeLimitBytes": 10485760,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] \ud83d\ude8c {Message:lj}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Debug"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "..\\logs\\errors-actionable-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true,
          "fileSizeLimitBytes": 5242880,
          "outputTemplate": "\ud83d\udea8 [{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] ACTIONABLE ERROR{NewLine}\ud83d\udccd Source: {SourceContext}{NewLine}\ud83d\udcac Message: {Message:lj}{NewLine}\ud83d\udd27 Action Required: Review and fix{NewLine}\ud83d\udcca Context: {Properties:j}{NewLine}\ud83d\udccb Exception: {Exception}{NewLine}\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550{NewLine}",
          "restrictedToMinimumLevel": "Error"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "..\\logs\\application.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Debug"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "..\\logs\\ui-interactions-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 3,
          "shared": true,
          "fileSizeLimitBytes": 5242880,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} \ud83d\ude8c {Message:lj}{NewLine}",
          "restrictedToMinimumLevel": "Information"
        }
      }
    ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "Contains(@m, 'Dispatcher unhandled exception suppressed') and Contains(@m, 'ButtonAdv')"
        }
      },
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "Contains(@m, 'Set property') and Contains(@m, 'TargetType does not match')"
        }
      }
    ]
  },
  "Syncfusion": {
    "NoExternalPackages": true,
    "SamplesPath": "C:\\Program Files (x86)\\Syncfusion\\Essential Studio\\Windows\\30.1.37\\Samples",
    "UseLocalResourcesOnly": true,
    "LocalInstallationPath": "C:\\Program Files (x86)\\Syncfusion\\Essential Studio\\Windows\\30.1.37",
    "LicenseKey": "${SYNCFUSION_LICENSE_KEY}",
    "DocumentationPath": "C:\\Program Files (x86)\\Syncfusion\\Essential Studio\\Windows\\30.1.37\\Help"
  },
  "UI": {
    "DefaultTheme": "FluentDark",
    "EnableAnimations": true,
    "ResponsiveLayout": true,
    "DebugMode": true
  }
}
