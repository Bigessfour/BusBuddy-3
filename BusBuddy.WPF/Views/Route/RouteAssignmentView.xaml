<UserControl x:Class="BusBuddy.WPF.Views.Route.RouteAssignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:views="clr-namespace:BusBuddy.WPF.Views.Route"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:models="clr-namespace:BusBuddy.Core.Models;assembly=BusBuddy.Core"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Centralized Syncfusion theme/resources validated for this project -->
                <ResourceDictionary Source="/BusBuddy.WPF;component/Resources/SyncfusionV30_Validated_ResourceDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <!-- Enum provider for RouteTimeSlot (use as ItemsSource via StaticResource) -->
            <ObjectDataProvider x:Key="RouteTimeSlotValues"
                                MethodName="GetValues"
                                ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="models:RouteTimeSlot" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
            <!-- Themed button styles for readability -->
            <Style x:Key="PrimaryButtonAdv"
                   TargetType="syncfusion:ButtonAdv">
                <Setter Property="Padding"
                        Value="14,8" />
                <Setter Property="Margin"
                        Value="6,0,0,0" />
                <Setter Property="Background"
                        Value="{DynamicResource BusBuddy.Brush.Primary}" />
                <Setter Property="Foreground"
                        Value="{DynamicResource BusBuddy.Brush.Text.OnPrimary}" />
            </Style>
            <Style x:Key="SuccessButtonAdv"
                   TargetType="syncfusion:ButtonAdv"
                   BasedOn="{StaticResource PrimaryButtonAdv}">
                <Setter Property="Background"
                        Value="{DynamicResource BusBuddy.Brush.Semantic.Success}" />
            </Style>
            <Style x:Key="WarningButtonAdv"
                   TargetType="syncfusion:ButtonAdv"
                   BasedOn="{StaticResource PrimaryButtonAdv}">
                <Setter Property="Background"
                        Value="{DynamicResource BusBuddy.Brush.Semantic.Warning}" />
            </Style>
            <Style x:Key="DangerButtonAdv"
                   TargetType="syncfusion:ButtonAdv"
                   BasedOn="{StaticResource PrimaryButtonAdv}">
                <Setter Property="Background"
                        Value="{DynamicResource BusBuddy.Brush.Semantic.Danger}" />
            </Style>
            <Style x:Key="InfoButtonAdv"
                   TargetType="syncfusion:ButtonAdv"
                   BasedOn="{StaticResource PrimaryButtonAdv}">
                <Setter Property="Background"
                        Value="{DynamicResource BusBuddy.Brush.Semantic.Info}" />
                <Setter Property="Foreground"
                        Value="{DynamicResource BusBuddy.Brush.Text.Primary}" />
            </Style>
            <!-- Watermark search uses SfTextBoxExt (Syncfusion only) -->
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!-- Banner -->
        <Border Grid.Row="0"
                Background="{DynamicResource BusBuddy.Brush.Primary}"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="🛠️"
                           FontSize="22"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center" />
                <TextBlock Text="Route Assignment — MVP"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource BusBuddy.Brush.Text.OnPrimary}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
        <!-- Route Configuration Bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource BusBuddy.Brush.Surface.LightMode.Surface}"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Route Picker -->
                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            Margin="0,0,10,0">
                    <TextBlock Text="Route"
                               FontWeight="SemiBold" />
                    <syncfusion:ComboBoxAdv x:Name="RoutePicker"
                                            ItemsSource="{Binding AvailableRoutes}"
                                            DisplayMemberPath="RouteName"
                                            SelectedItem="{Binding SelectedRoute, Mode=TwoWay}"
                                            MaxDropDownHeight="240"
                                            AutomationProperties.Name="Route Selector"
                                            ToolTip="Select a route to manage" />
                </StackPanel>
                <!-- Date -->
                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            Margin="0,0,10,0">
                    <TextBlock Text="Date"
                               FontWeight="SemiBold" />
                    <syncfusion:SfDatePicker x:Name="RouteDatePicker"
                                             Value="{Binding SelectedRoute.Date, Mode=TwoWay}"
                                             AutomationProperties.Name="Route Date" />
                </StackPanel>
                <!-- Time Slot -->
                <StackPanel Grid.Column="2"
                            Orientation="Vertical"
                            Margin="0,0,10,0">
                    <TextBlock Text="Time Slot"
                               FontWeight="SemiBold" />
                    <syncfusion:ComboBoxAdv x:Name="TimeSlotCombo"
                                            SelectedItem="{Binding SelectedTimeSlot, Mode=TwoWay}"
                                            ItemsSource="{Binding Source={StaticResource RouteTimeSlotValues}}"
                                            AutomationProperties.Name="Route Time Slot" />
                </StackPanel>
                <!-- Bus -->
                <StackPanel Grid.Column="3"
                            Orientation="Vertical"
                            Margin="0,0,10,0">
                    <TextBlock Text="Bus"
                               FontWeight="SemiBold" />
                    <syncfusion:ComboBoxAdv x:Name="BusCombo"
                                            ItemsSource="{Binding AvailableBuses}"
                                            DisplayMemberPath="BusNumber"
                                            SelectedItem="{Binding SelectedBus, Mode=TwoWay}"
                                            MaxDropDownHeight="240"
                                            AutomationProperties.Name="Bus Selector"
                                            AutomationProperties.HelpText="Select a bus for the route" />
                </StackPanel>
                <!-- Driver -->
                <StackPanel Grid.Column="4"
                            Orientation="Vertical"
                            Margin="0,0,10,0">
                    <TextBlock Text="Driver"
                               FontWeight="SemiBold" />
                    <syncfusion:ComboBoxAdv x:Name="DriverCombo"
                                            ItemsSource="{Binding AvailableDrivers}"
                                            DisplayMemberPath="DriverName"
                                            SelectedItem="{Binding SelectedDriver, Mode=TwoWay}"
                                            MaxDropDownHeight="240"
                                            AutomationProperties.Name="Driver Selector"
                                            AutomationProperties.HelpText="Select a driver for the route" />
                </StackPanel>
                <!-- Start Time and Actions -->
                <StackPanel Grid.Column="5"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <TextBlock Text="Start:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <syncfusion:SfMaskedEdit x:Name="StartTimeInput"
                                             Width="80"
                                             Text="{Binding StartTimeString, Mode=TwoWay}"
                                             AutomationProperties.Name="Route Start Time" />
                    <syncfusion:ButtonAdv x:Name="TimeButton"
                                          Label="⏱️ Time"
                                          Command="{Binding TimeRouteCommand}"
                                          Style="{StaticResource InfoButtonAdv}"
                                          AutomationProperties.Name="Time Route"
                                          ToolTip="Calculate timing for all stops" />
                    <syncfusion:ButtonAdv x:Name="SaveButton"
                                          Label="💾 Save"
                                          Command="{Binding SaveRouteCommand}"
                                          Style="{StaticResource PrimaryButtonAdv}"
                                          AutomationProperties.Name="Save Route"
                                          ToolTip="Save route and assignments" />
                    <syncfusion:ButtonAdv x:Name="ActivateButton"
                                          Label="✅ Activate"
                                          Command="{Binding ActivateRouteCommand}"
                                          Style="{StaticResource SuccessButtonAdv}"
                                          AutomationProperties.Name="Activate Route" />
                    <syncfusion:ButtonAdv x:Name="DeactivateButton"
                                          Label="🛑 Deactivate"
                                          Command="{Binding DeactivateRouteCommand}"
                                          Style="{StaticResource WarningButtonAdv}"
                                          AutomationProperties.Name="Deactivate Route" />
                    <syncfusion:ButtonAdv x:Name="DeleteButton"
                                          Label="🗑️ Delete"
                                          Command="{Binding DeleteRouteCommand}"
                                          Style="{StaticResource DangerButtonAdv}"
                                          AutomationProperties.Name="Delete Route" />
                    <syncfusion:ButtonAdv x:Name="ScheduleButton"
                                          Label="🗓️ Schedule"
                                          Command="{Binding ViewScheduleCommand}"
                                          Style="{StaticResource InfoButtonAdv}"
                                          AutomationProperties.Name="View Schedule" />
                    <syncfusion:ButtonAdv x:Name="PlotButton"
                                          Label="🗺️ Plot"
                                          Command="{Binding PlotRouteOnMapCommand}"
                                          Style="{StaticResource InfoButtonAdv}"
                                          AutomationProperties.Name="Plot Route on Map" />
                    <syncfusion:ButtonAdv x:Name="PrintMapButton"
                                          Label="🖨️ Print Map"
                                          Command="{Binding PrintMapCommand}"
                                          Style="{StaticResource PrimaryButtonAdv}"
                                          AutomationProperties.Name="Print Route Map" />
                    <syncfusion:ButtonAdv x:Name="AutoAssignButton"
                                          Label="⚡ Auto-Assign"
                                          Command="{Binding AutoAssignCommand}"
                                          Style="{StaticResource SuccessButtonAdv}"
                                          AutomationProperties.Name="Auto Assign Students"
                                          ToolTip="Assign unassigned students up to route capacity for the selected time slot" />
                    <syncfusion:ButtonAdv x:Name="ReportButton"
                                          Label="📄 Report"
                                          Command="{Binding GenerateReportCommand}"
                                          Style="{StaticResource InfoButtonAdv}"
                                          AutomationProperties.Name="Generate Route Assignment Report"
                                          ToolTip="Export route assignment summary PDF" />
                </StackPanel>
            </Grid>
        </Border>
        <!-- Main Content: Unassigned ↔ Assigned -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <!-- Unassigned Students -->
            <GroupBox Grid.Column="0"
                      Header="📚 Unassigned Students"
                      Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <syncfusion:SfTextBoxExt x:Name="UnassignedSearchBox"
                                             Grid.Row="0"
                                             Margin="0,0,0,8"
                                             Watermark="🔍 Search unassigned students..."
                                             Text="{Binding StudentSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="Unassigned Student Search"
                                             ToolTip="Search unassigned students" />
                    <syncfusion:SfDataGrid Grid.Row="1"
                                           x:Name="UnassignedStudentsGrid"
                                           ItemsSource="{Binding UnassignedStudents}"
                                           SelectedItem="{Binding SelectedStudent, Mode=TwoWay}"
                                           AutoGenerateColumns="False"
                                           AllowSorting="True"
                                           AllowFiltering="True"
                                           AllowGrouping="True"
                                           ShowGroupDropArea="True"
                                           SelectionMode="Single"
                                           GridLinesVisibility="Both"
                                           ColumnSizer="Star"
                                           AllowDrop="True"
                                           PreviewMouseLeftButtonDown="UnassignedGrid_PreviewMouseLeftButtonDown"
                                           PreviewMouseMove="Grid_PreviewMouseMove"
                                           DragOver="UnassignedGrid_DragOver"
                                           Drop="UnassignedGrid_Drop"
                                           DragEnter="UnassignedGrid_DragEnter"
                                           DragLeave="UnassignedGrid_DragLeave"
                                           AutomationProperties.Name="Unassigned Students Grid"
                                           AutomationProperties.HelpText="Students not yet assigned to the selected route">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="Name"
                                                       MappingName="StudentName"
                                                       Width="150" />
                            <syncfusion:GridTextColumn HeaderText="Grade"
                                                       MappingName="Grade"
                                                       Width="70" />
                            <syncfusion:GridTextColumn HeaderText="Address"
                                                       MappingName="HomeAddress"
                                                       Width="200" />
                            <syncfusion:GridTextColumn HeaderText="City"
                                                       MappingName="City"
                                                       Width="120" />
                        </syncfusion:SfDataGrid.Columns>
                    </syncfusion:SfDataGrid>
                    <TextBlock Grid.Row="2"
                               Text="{Binding UnassignedStudentCount, StringFormat=Unassigned: {0}}" />
                </Grid>
            </GroupBox>
            <!-- Actions -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">
                <syncfusion:ButtonAdv x:Name="AssignButton"
                                      Label="➡️ Assign"
                                      Command="{Binding AssignStudentCommand}"
                                      Margin="0,0,0,10"
                                      Padding="16,8"
                                      AutomationProperties.Name="Assign Student"
                                      ToolTip="Assign selected student to route" />
                <syncfusion:ButtonAdv x:Name="RemoveButton"
                                      Label="⬅️ Remove"
                                      Command="{Binding RemoveStudentCommand}"
                                      Padding="16,8"
                                      AutomationProperties.Name="Remove Student"
                                      ToolTip="Remove selected student from route" />
            </StackPanel>
            <!-- Assigned Students -->
            <GroupBox Grid.Column="2"
                      Header="✅ Assigned to Route">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <syncfusion:SfDataGrid Grid.Row="0"
                                           x:Name="AssignedStudentsGrid"
                                           ItemsSource="{Binding AssignedStudentsForSelectedRoute}"
                                           SelectedItem="{Binding SelectedAssignedStudent, Mode=TwoWay}"
                                           AutoGenerateColumns="False"
                                           AllowSorting="True"
                                           AllowFiltering="True"
                                           AllowGrouping="True"
                                           ShowGroupDropArea="True"
                                           SelectionMode="Single"
                                           GridLinesVisibility="Both"
                                           ColumnSizer="Star"
                                           AllowDrop="True"
                                           PreviewMouseLeftButtonDown="AssignedGrid_PreviewMouseLeftButtonDown"
                                           PreviewMouseMove="Grid_PreviewMouseMove"
                                           DragOver="AssignedGrid_DragOver"
                                           Drop="AssignedGrid_Drop"
                                           DragEnter="AssignedGrid_DragEnter"
                                           DragLeave="AssignedGrid_DragLeave"
                                           AutomationProperties.Name="Assigned Students Grid"
                                           AutomationProperties.HelpText="Students assigned to the selected route">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="Name"
                                                       MappingName="StudentName"
                                                       Width="150" />
                            <syncfusion:GridTextColumn HeaderText="Grade"
                                                       MappingName="Grade"
                                                       Width="70" />
                            <syncfusion:GridTextColumn HeaderText="Address"
                                                       MappingName="HomeAddress"
                                                       Width="200" />
                            <syncfusion:GridTextColumn HeaderText="City"
                                                       MappingName="City"
                                                       Width="120" />
                        </syncfusion:SfDataGrid.Columns>
                    </syncfusion:SfDataGrid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding AssignedStudentCount, StringFormat=Assigned: {0}}" />
                </Grid>
            </GroupBox>
        </Grid>
        <!-- Stops Editor -->
        <GroupBox Grid.Row="3"
                  Header="🧭 Route Stops"
                  Margin="0,12,0,0">
            <views:RouteStopsEditor />
        </GroupBox>
        <!-- Footer / Status -->
        <Border Grid.Row="4"
                Margin="0,12,0,0"
                Background="{DynamicResource BusBuddy.Brush.Surface.LightMode.Surface}"
                CornerRadius="6"
                Padding="10">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource BusBuddy.Brush.Text.Secondary}" />
        </Border>
    </Grid>
</UserControl>
