<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="BusBuddy.WPF.Views.Activity.ActivityTimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:syncfusiontools="clr-namespace:Syncfusion.Windows.Tools.Controls;assembly=Syncfusion.Tools.WPF"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PrimaryBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="20,10,20,0" Padding="12"
                Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Activity Timeline" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <syncfusion:ButtonAdv Grid.Column="1" Label="🔄 Refresh"
                                      Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Date Range:" VerticalAlignment="Center" Grid.Column="0" Grid.Row="0" Margin="0,0,8,0"/>
                <syncfusion:ComboBoxAdv Grid.Column="1" Grid.Row="0" SelectedItem="{Binding SelectedDateRange}"
                                        ItemsSource="{Binding DateRanges}" Width="160" Margin="0,0,15,0">
                    <syncfusion:ComboBoxAdv.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </syncfusion:ComboBoxAdv.ItemTemplate>
                </syncfusion:ComboBoxAdv>

                <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal"
                            Visibility="{Binding IsCustomDateRange, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <syncfusion:SfDatePicker Value="{Binding StartDate}" Width="130" Margin="0,0,10,0"/>
                    <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <syncfusion:SfDatePicker Value="{Binding EndDate}" Width="130"/>
                </StackPanel>

                <TextBlock Text="Event Types:" VerticalAlignment="Top" Grid.Column="0" Grid.Row="1" Margin="0,12,8,0"/>
                <ItemsControl Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="3"
                              ItemsSource="{Binding EventTypes}" Margin="0,10,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <syncfusiontools:ToggleButtonExt Content="{Binding DisplayName}"
                                                           IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                           Margin="0,0,16,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <syncfusion:SfDataGrid Grid.Row="1"
                                   ItemsSource="{Binding TimelineEvents}"
                                   AutoGenerateColumns="False"
                                   AllowSorting="True"
                                   AllowFiltering="True"
                                   ColumnSizer="Star">
                <syncfusion:SfDataGrid.Columns>
                    <syncfusion:GridTextColumn HeaderText="Subject" MappingName="Subject" Width="220"/>
                    <syncfusion:GridDateTimeColumn HeaderText="Start" MappingName="StartTime" Width="160" Pattern="ShortDateTime"/>
                    <syncfusion:GridDateTimeColumn HeaderText="End" MappingName="EndTime" Width="160" Pattern="ShortDateTime"/>
                    <syncfusion:GridTextColumn HeaderText="Details" MappingName="Details" Width="*"/>
                </syncfusion:SfDataGrid.Columns>
            </syncfusion:SfDataGrid>

            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="0,8,0,0" Margin="0,10,0,0">
                <ItemsControl ItemsSource="{Binding EventLegendItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <Rectangle Width="12" Height="12" Fill="{Binding Color}" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Border Grid.RowSpan="3" Background="#80000000"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <syncfusion:SfBusyIndicator IsBusy="True" AnimationType="Ball"/>
                    <TextBlock Text="Loading timeline data..." Margin="0,12,0,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="Transparent"
                    Visibility="{Binding HasNoData, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="No activity data found for the selected filters"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="16"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
