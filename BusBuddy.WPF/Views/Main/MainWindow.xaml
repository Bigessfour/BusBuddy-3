<!-- 
    BusBuddy Main Window - Transportation Management System
    
    This is the primary user interface for the BusBuddy transportation management system.
    Features include:
    - Student management with data grid display
    - Route planning and optimization tools
    - Bus fleet management and maintenance tracking
    - Driver scheduling and assignment
    - Integrated Google Earth mapping
    - PDF generation for eligibility reports
    - Professional Syncfusion WPF controls with FluentDark/Light themes
    
    Architecture:
    - Uses Syncfusion ChromelessWindow for modern appearance
    - DockingManager provides professional layout with dockable panels
    - MVVM pattern with data binding throughout
    - Responsive design with theme switching capabilities
    
    Syncfusion API Enhancements Applied:
    - ChromelessWindow with proper title bar configuration
    - DockingManager with UseDocumentContainer and PersistState
    - SfDataGrid with advanced column types and styling
    - ButtonAdv controls with enhanced styling and interaction
    - ComboBoxAdv with theme-aware appearance
    - Professional visual styles and theme management
-->
<syncfusion:ChromelessWindow x:Class="BusBuddy.WPF.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:route="clr-namespace:BusBuddy.WPF.Views.Route"
        xmlns:viewsGE="clr-namespace:BusBuddy.WPF.Views.GoogleEarth"
        mc:Ignorable="d"
        Title="🚌 BusBuddy MVP - Student Route Management"
        Height="900"
        Width="1400"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        TitleBarBackground="{DynamicResource BusBuddy.Brush.Header.Background}"
        TitleBarHeight="50"
        TitleFontSize="16"
        TitleTextAlignment="Center"
        IconAlignment="Left"
        ResizeBorderBrush="{DynamicResource BusBuddy.Brush.Primary}"
        UseNativeChrome="False"
        ShowMaximizeButton="True"
        ShowMinimizeButton="True">

    <!-- Theme resources are managed in App.xaml using Syncfusion FluentDark/FluentLight themes -->

    <!-- Main UI Layout: Three-row grid with header, content area, and status bar -->
    <Grid>
        <!-- Define three main sections: Header (Auto), Content (Star), Status Bar (Auto) -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header with navigation and controls -->
            <RowDefinition Height="*"/>      <!-- Main content area with DockingManager -->
            <RowDefinition Height="Auto"/>   <!-- Status bar with system information -->
        </Grid.RowDefinitions>

        <!-- =================================================================== -->
        <!-- HEADER SECTION: Navigation, PDF Controls, and Theme Selector       -->
        <!-- =================================================================== -->
        <Border Grid.Row="0" Background="{DynamicResource BusBuddy.Brush.Header.Background}" Padding="20">
            <Grid>
                <!-- Header layout: Title, subtitle, and navigation controls in three rows -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Main application title -->
                    <RowDefinition Height="Auto"/>   <!-- Subtitle with module list -->
                    <RowDefinition Height="Auto"/>   <!-- Navigation buttons and theme controls -->
                </Grid.RowDefinitions>

                <!-- Application Title -->
                <TextBlock Grid.Row="0" Text="🚌 BusBuddy MVP - Transportation Management"
                           FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                           HorizontalAlignment="Center"/>
                
                <!-- Subtitle describing main modules -->
                <TextBlock Grid.Row="1" Text="Students | Routes | Buses | Drivers - Monday Ready Demo"
                           FontSize="16" Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}" Opacity="0.9"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>

                <!-- Navigation Controls: PDF generation, module navigation, and theme selection -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    
                    <!-- =============================================== -->
                    <!-- PDF GENERATION CONTROLS                        -->
                    <!-- =============================================== -->
                    
                    <!-- Primary PDF Generation Button: Creates eligibility route reports -->
                    <syncfusion:ButtonAdv Label="🧾 Eligibility PDF" Margin="0,0,18,0" Padding="15,8"
                                          Background="{DynamicResource BusBuddy.Brush.Primary}" 
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}" 
                                          BorderThickness="0"
                                          Command="{Binding GenerateEligibilityPdfCommand}"
                                          FontSize="14" FontWeight="SemiBold"
                                          ToolTip="Generate eligibility route PDF (district outside town, excludes Lamar)"
                                          AutomationProperties.Name="Generate Eligibility PDF"
                                          SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/pdf-icon.png"
                                          SizeMode="Large">
                        <!-- Enhanced button styling with hover effects and drop shadows -->
                        <syncfusion:ButtonAdv.Style>
                            <Style TargetType="syncfusion:ButtonAdv">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Primary.Hover}"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Primary.Pressed}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </syncfusion:ButtonAdv.Style>
                    </syncfusion:ButtonAdv>

                    <!-- PDF Printing Button: Prints the last generated eligibility PDF -->
                    <syncfusion:ButtonAdv Label="Print Last PDF" Margin="0,0,25,0" Padding="15,8"
                                          Background="{DynamicResource BusBuddy.Brush.Primary}" 
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}" 
                                          BorderThickness="0"
                                          Command="{Binding PrintEligibilityPdfCommand}"
                                          FontSize="14" FontWeight="SemiBold"
                                          ToolTip="Print the last generated eligibility PDF (opens system print dialog)"
                                          AutomationProperties.Name="Print Eligibility PDF"
                                          SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/print-icon.png"
                                          SizeMode="Large">
                        <syncfusion:ButtonAdv.Style>
                            <Style TargetType="syncfusion:ButtonAdv">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Primary.Hover}"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Primary.Pressed}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </syncfusion:ButtonAdv.Style>
                    </syncfusion:ButtonAdv>

                    <!-- =============================================== -->
                    <!-- MODULE NAVIGATION CONTROLS                     -->
                    <!-- =============================================== -->

                    <!-- Google Earth Map Integration Button -->
                    <syncfusion:ButtonAdv Label="🌍 Map" Margin="0,0,18,0" Padding="15,8"
                                          Background="{DynamicResource BusBuddy.Brush.Secondary}" 
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Secondary}" 
                                          BorderThickness="0"
                                          Command="{Binding NavigateToMapCommand}"
                                          FontSize="14" FontWeight="SemiBold"
                                          ToolTip="Show Google Earth / Geospatial Map with route visualization"
                                          AutomationProperties.Name="Map View Navigation"
                                          SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/map-icon.png"
                                          SizeMode="Large">

                        <syncfusion:ButtonAdv.Style>
                            <Style TargetType="syncfusion:ButtonAdv">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Secondary.Hover}"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </syncfusion:ButtonAdv.Style>
                    </syncfusion:ButtonAdv>

                    <!-- Students Management Module -->
                    <syncfusion:ButtonAdv Label="📚 Students" Margin="0,0,10,0" Padding="15,8"
                                          Background="{DynamicResource BusBuddy.Brush.Accent}" 
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}" 
                                          BorderThickness="0"
                                          Command="{Binding NavigateToStudentsCommand}"
                                          FontSize="14" FontWeight="SemiBold"
                                          ToolTip="Manage student records and route assignments"
                                          AutomationProperties.Name="Students Management"
                                          SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/students-icon.png"
                                          SizeMode="Large" />

                    <!-- Route Management Module -->
                    <syncfusion:ButtonAdv Label="🚌 Routes" Margin="0,0,10,0" Padding="15,8"
                                          Background="{DynamicResource BusBuddy.Brush.Accent}" 
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}" 
                                          BorderThickness="0"
                                          Command="{Binding NavigateToRoutesCommand}"
                                          FontSize="14" FontWeight="SemiBold"
                                          ToolTip="Plan and manage transportation routes with optimization"
                                          AutomationProperties.Name="Route Management"
                                          SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/routes-icon.png"
                                          SizeMode="Large" />

                    <!-- Bus Fleet Management Module -->
                    <syncfusion:ButtonAdv Label="🚐 Buses" Margin="0,0,10,0" Padding="15,8"
                                          Background="{DynamicResource BusBuddy.Brush.Accent}" 
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}" 
                                          BorderThickness="0"
                                          Command="{Binding NavigateToBusesCommand}"
                                          FontSize="14" FontWeight="SemiBold"
                                          ToolTip="Manage bus fleet and vehicle maintenance information"
                                          AutomationProperties.Name="Bus Management"
                                          SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/buses-icon.png"
                                          SizeMode="Large" />

                    <!-- Driver Management Module -->
                    <syncfusion:ButtonAdv Label="👨‍✈️ Drivers" Margin="0,0,10,0" Padding="15,8"
                                          Background="{DynamicResource BusBuddy.Brush.Accent}" 
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}" 
                                          BorderThickness="0"
                                          Command="{Binding NavigateToDriversCommand}"
                                          FontSize="14" FontWeight="SemiBold"
                                          ToolTip="Manage driver information and route schedules"
                                          AutomationProperties.Name="Driver Management"
                                          SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/drivers-icon.png"
                                          SizeMode="Large" />

                    <!-- Reports and Analytics Module -->
                    <syncfusion:ButtonAdv Label="📊 Reports" Padding="15,8"
                                          Background="{DynamicResource BusBuddy.Brush.Success}" 
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Success}" 
                                          BorderThickness="0"
                                          Command="{Binding NavigateToReportsCommand}"
                                          FontSize="14" FontWeight="SemiBold"
                                          ToolTip="Generate comprehensive transportation reports and analytics"
                                          AutomationProperties.Name="Reports and Analytics"
                                          SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/reports-icon.png"
                                          SizeMode="Large" />

                    <!-- =============================================== -->
                    <!-- THEME SELECTION CONTROLS                       -->
                    <!-- =============================================== -->

                    <!-- Theme Selection Panel: Dropdown and quick toggle buttons -->
                    <StackPanel Orientation="Horizontal" Margin="30,0,0,0" VerticalAlignment="Center">
                        <!-- Theme label -->
                        <TextBlock Text="Theme:" 
                                   Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,10,0" 
                                   FontSize="14" 
                                   FontWeight="Medium"/>
                        
                        <!-- Theme dropdown: FluentDark and FluentLight options with professional styling -->
                        <syncfusion:ComboBoxAdv x:Name="ThemeSelector" 
                                               Width="180" 
                                               Height="36"
                                               SelectedIndex="0"
                                               SelectionChanged="{Binding ChangeThemeCommand}"
                                               Style="{DynamicResource BusBuddyComboBoxAdvStyle}"
                                               Background="{DynamicResource BusBuddy.Brush.Secondary.Background}"
                                               BorderBrush="{DynamicResource BusBuddy.Brush.Border}"
                                               BorderThickness="1"
                                               Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                               MaxDropDownHeight="200"
                                               IsEditable="False"
                                               AllowMultiSelect="False"
                                               AutomationProperties.Name="Theme Selector"
                                               ToolTip="Select application theme (FluentDark recommended)"
                                               VerticalContentAlignment="Center"
                                               Padding="12,0"
                                               FontSize="14"
                                               FontFamily="{DynamicResource BusBuddy.FontFamily.Primary}">
                            <!-- Enhanced ComboBoxItemAdv with proper theming support -->
                            <syncfusion:ComboBoxItemAdv Content="🌙 FluentDark" 
                                                       Tag="FluentDark"
                                                       AutomationProperties.Name="Dark Theme Option"
                                                       ToolTip="Syncfusion FluentDark theme - Professional dark interface"
                                                       Background="{DynamicResource BusBuddy.Brush.Secondary.Background}"
                                                       Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                                       BorderThickness="0"
                                                       Padding="12,8"
                                                       FontSize="14"/>
                            <syncfusion:ComboBoxItemAdv Content="☀️ FluentLight" 
                                                       Tag="FluentLight"
                                                       AutomationProperties.Name="Light Theme Option"
                                                       ToolTip="Syncfusion FluentLight theme - Clean light interface"
                                                       Background="{DynamicResource BusBuddy.Brush.Secondary.Background}"
                                                       Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                                       BorderThickness="0"
                                                       Padding="12,8"
                                                       FontSize="14"/>
                        </syncfusion:ComboBoxAdv>

                        <!-- Enhanced Theme Toggle Buttons with professional styling -->
                        <!-- Dark Theme Toggle Button -->
                        <syncfusion:ButtonAdv Label="🌙" 
                                             Width="48" Height="40"
                                             Margin="12,0,0,0" 
                                             Padding="8" 
                                             ToolTip="Switch to FluentDark theme - Professional dark interface" 
                                             Command="{Binding SwitchToDarkThemeCommand}"
                                             Background="{DynamicResource BusBuddy.Brush.Control.Background}" 
                                             Foreground="{DynamicResource BusBuddy.Brush.Control.Text}"
                                             BorderBrush="{DynamicResource BusBuddy.Brush.Control.Border}"
                                             BorderThickness="2"
                                             CornerRadius="6"
                                             AutomationProperties.Name="Switch to Dark Theme"
                                             FontSize="18"
                                             FontFamily="{DynamicResource BusBuddy.FontFamily.Primary}"
                                             IsDefault="False"
                                             IconTemplate="{x:Null}"
                                             SmallIcon="{x:Null}"
                                             LargeIcon="{x:Null}"
                                             SizeMode="Normal">
                            <!-- Professional dark theme button styling -->
                            <syncfusion:ButtonAdv.Style>
                                <Style TargetType="syncfusion:ButtonAdv">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="syncfusion:ButtonAdv">
                                                <Border x:Name="Border"
                                                       Background="{TemplateBinding Background}"
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       BorderThickness="{TemplateBinding BorderThickness}"
                                                       CornerRadius="{TemplateBinding CornerRadius}"
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Content="{TemplateBinding Label}"
                                                                     TextElement.Foreground="{TemplateBinding Foreground}"
                                                                     TextElement.FontSize="{TemplateBinding FontSize}"
                                                                     TextElement.FontFamily="{TemplateBinding FontFamily}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource BusBuddy.Brush.Control.Hover}"/>
                                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BusBuddy.Brush.Primary}"/>
                                                        <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource BusBuddy.Brush.Control.Pressed}"/>
                                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BusBuddy.Brush.Primary}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </syncfusion:ButtonAdv.Style>
                        </syncfusion:ButtonAdv>

                        <!-- Light Theme Toggle Button -->
                        <syncfusion:ButtonAdv Label="☀️" 
                                             Width="48" Height="40"
                                             Margin="6,0,0,0" 
                                             Padding="8" 
                                             ToolTip="Switch to FluentLight theme - Clean light interface" 
                                             Command="{Binding SwitchToLightThemeCommand}"
                                             Background="{DynamicResource BusBuddy.Brush.Control.Background}" 
                                             Foreground="{DynamicResource BusBuddy.Brush.Control.Text}"
                                             BorderBrush="{DynamicResource BusBuddy.Brush.Control.Border}"
                                             BorderThickness="2"
                                             CornerRadius="6"
                                             AutomationProperties.Name="Switch to Light Theme"
                                             FontSize="18"
                                             FontFamily="{DynamicResource BusBuddy.FontFamily.Primary}"
                                             IsDefault="False"
                                             IconTemplate="{x:Null}"
                                             SmallIcon="{x:Null}"
                                             LargeIcon="{x:Null}"
                                             SizeMode="Normal">
                            <!-- Professional light theme button styling -->
                            <syncfusion:ButtonAdv.Style>
                                <Style TargetType="syncfusion:ButtonAdv">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="syncfusion:ButtonAdv">
                                                <Border x:Name="Border"
                                                       Background="{TemplateBinding Background}"
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       BorderThickness="{TemplateBinding BorderThickness}"
                                                       CornerRadius="{TemplateBinding CornerRadius}"
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Content="{TemplateBinding Label}"
                                                                     TextElement.Foreground="{TemplateBinding Foreground}"
                                                                     TextElement.FontSize="{TemplateBinding FontSize}"
                                                                     TextElement.FontFamily="{TemplateBinding FontFamily}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource BusBuddy.Brush.Control.Hover}"/>
                                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BusBuddy.Brush.Warning}"/>
                                                        <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource BusBuddy.Brush.Control.Pressed}"/>
                                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BusBuddy.Brush.Warning}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </syncfusion:ButtonAdv.Style>
                        </syncfusion:ButtonAdv>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =================================================================== -->
        <!-- MAIN CONTENT AREA: DockingManager with Professional Layout         -->
        <!-- =================================================================== -->
        
        <!-- 
            Syncfusion DockingManager provides professional docking layout with:
            - Document container for tabbed main content
            - Dockable panels for Students (left) and Routes (right)
            - Document tabs for Buses, Drivers, Map, and Route Assignment
            - Persistent state management for user preferences
            
            Enhanced Syncfusion API Configuration:
            - UseDocumentContainer: Enables tabbed document interface
            - PersistState: Automatically saves/restores layout
            - ContainerMode: Sets appropriate document container behavior
            - DocumentContainerStyle: Professional document tab styling
            - AnimationController: Smooth transitions and animations
        -->
        <syncfusion:DockingManager Name="MainDockingManager"
                                   UseDocumentContainer="True"
                                   PersistState="True"
                                   ContainerMode="TDI"
                                   DocumentContainerStyle="VS2010"
                                   AnimationEnabled="True"
                                   AutoHideAnimationMode="Slide"
                                   DockFill="True"
                                   ShowAutoHideButton="True"
                                   ShowMaximizeButton="True"
                                   ShowMinimizeButton="True"
                                   ShowPinButton="True"
                                   Grid.Row="1">

            <!-- DockingManager Resources: Custom templates and enhanced styling -->
            <syncfusion:DockingManager.Resources>
                <!-- Document Header Template: Professional styling for document tab headers -->
                <DataTemplate x:Key="DocumentHeaderTemplate">
                    <StackPanel Orientation="Horizontal" Margin="8,4">
                        <TextBlock Text="{Binding}" 
                                   FontSize="13" 
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
                
                <!-- Dock Header Template: Enhanced styling for docked panel headers -->
                <DataTemplate x:Key="DockHeaderTemplate">
                    <StackPanel Orientation="Horizontal" Margin="6,3">
                        <TextBlock Text="{Binding}" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BusBuddy.Brush.Text.Secondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
                
                <!-- AutoHidden Tab Style: Professional appearance for auto-hidden tabs -->
                <Style x:Key="AutoHiddenTabStyle" TargetType="ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Control.Background}"/>
                    <Setter Property="TextBlock.Foreground" Value="{DynamicResource BusBuddy.Brush.Control.Text}"/>
                </Style>
            </syncfusion:DockingManager.Resources>

            <!-- =============================================== -->
            <!-- STUDENTS PANEL: Left-docked student management -->
            <!-- =============================================== -->
            
            <!-- 
                Students Panel: Left-docked panel with enhanced configuration
                - Professional docking with proper sizing and constraints
                - Enhanced SfDataGrid with column formatting and validation
                - Proper header template and tooltip configuration
                - Auto-hide capabilities and resize constraints
            -->
            <ContentControl x:Name="StudentsPane"
                            syncfusion:DockingManager.Header="📚 Students"
                            syncfusion:DockingManager.State="Dock"
                            syncfusion:DockingManager.SideInDockedMode="Left"
                            syncfusion:DockingManager.DesiredWidthInDockedMode="350"
                            syncfusion:DockingManager.DesiredHeightInDockedMode="400"
                            syncfusion:DockingManager.SizetoContentInDock="True"
                            syncfusion:DockingManager.CanAutoHide="True"
                            syncfusion:DockingManager.CanClose="False"
                            syncfusion:DockingManager.CanFloat="True"
                            syncfusion:DockingManager.CanDock="True"
                            syncfusion:DockingManager.CaptionToolTip="Student Management Panel - Add, edit, and manage student information"
                            Background="{DynamicResource BusBuddy.Brush.Panel.Background}">
                <Grid Margin="15" Background="{DynamicResource BusBuddy.Brush.Panel.Content}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <syncfusion:SfDataGrid Grid.Row="0" x:Name="StudentsGrid"
                                          ItemsSource="{Binding Students}"
                                          AutoGenerateColumns="False"
                                          AllowEditing="False"
                                          AllowSorting="True"
                                          AllowFiltering="True"
                                          AllowGrouping="True"
                                          AllowResizingColumns="True"
                                          AllowDraggingColumns="True"
                                          ShowGroupDropArea="True"
                                          SelectionMode="Single"
                                          SelectionUnit="Row"
                                          GridLinesVisibility="Both"
                                          HeaderLinesVisibility="Both"
                                          RowHeight="32"
                                          HeaderRowHeight="38"
                                          GroupCaptionTextFormat="{}{Key}: {ItemsCount} Students"
                                          ColumnSizer="Star"
                                          NavigationMode="Row"
                                          Background="{DynamicResource BusBuddy.Brush.DataGrid.Background}"
                                          AutomationProperties.Name="Students Data Grid"
                                          ToolTip="List of all students with their information - Click headers to sort, drag to group">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="Student #" 
                                                     MappingName="StudentNumber" 
                                                     Width="100"
                                                     TextAlignment="Center"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"/>
                            <syncfusion:GridTextColumn HeaderText="Name" 
                                                     MappingName="StudentName" 
                                                     Width="140"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"/>
                            <syncfusion:GridTextColumn HeaderText="Grade" 
                                                     MappingName="Grade" 
                                                     Width="60"
                                                     TextAlignment="Center"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"/>
                            <syncfusion:GridTextColumn HeaderText="Address" 
                                                     MappingName="HomeAddress" 
                                                     Width="180"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"
                                                     ShowToolTip="True"/>
                        </syncfusion:SfDataGrid.Columns>
                        
                        <!-- Enhanced Summary Rows -->
                        <syncfusion:SfDataGrid.TableSummaryRows>
                            <syncfusion:GridTableSummaryRow Title="Total Students: {TotalSummary}" 
                                                          Position="Bottom" 
                                                          ShowSummaryInRow="True">
                                <syncfusion:GridTableSummaryRow.SummaryColumns>
                                    <syncfusion:GridSummaryColumn Name="TotalSummary" 
                                                                Format="'{Count}'" 
                                                                MappingName="StudentNumber" 
                                                                SummaryType="CountAggregate"/>
                                </syncfusion:GridTableSummaryRow.SummaryColumns>
                            </syncfusion:GridTableSummaryRow>
                        </syncfusion:SfDataGrid.TableSummaryRows>
                    </syncfusion:SfDataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,0">
                        <syncfusion:ButtonAdv Label="➕ Add Student" Margin="0,0,10,0" Padding="12,6"
                                              Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource ButtonForegroundBrush}" BorderThickness="0"
                                              Command="{Binding AddStudentCommand}"
                                              ToolTip="Add a new student to the system"
                                              AutomationProperties.Name="Add New Student"/>
                        <syncfusion:ButtonAdv Label="📝 Edit Student" Padding="12,6"
                                              Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource ButtonForegroundBrush}" BorderThickness="0"
                                              Click="EditStudent_Click"
                                              ToolTip="Edit selected student information"
                                              AutomationProperties.Name="Edit Selected Student"/>
                    </StackPanel>
                </Grid>
            </ContentControl>

            <!-- Enhanced Routes Panel with comprehensive docking configuration -->
            <ContentControl x:Name="RoutesPane"
                            syncfusion:DockingManager.Header="🚌 Routes Management"
                            syncfusion:DockingManager.State="Dock"
                            syncfusion:DockingManager.SideInDockedMode="Right"
                            syncfusion:DockingManager.DesiredWidthInDockedMode="420"
                            syncfusion:DockingManager.DesiredHeightInDockedMode="500"
                            syncfusion:DockingManager.SizetoContentInDock="False"
                            syncfusion:DockingManager.CanAutoHide="True"
                            syncfusion:DockingManager.CanClose="False"
                            syncfusion:DockingManager.CanFloat="True"
                            syncfusion:DockingManager.CanDock="True"
                            syncfusion:DockingManager.CaptionToolTip="Route Management Panel - Plan, edit, and optimize bus routes"
                            Background="{DynamicResource BusBuddy.Brush.Panel.Background}">
                <Grid Margin="15" Background="{DynamicResource BusBuddy.Brush.Panel.Content}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <syncfusion:SfDataGrid Grid.Row="0" x:Name="RoutesGrid"
                                          ItemsSource="{Binding Routes}"
                                          AutoGenerateColumns="False"
                                          AllowEditing="False"
                                          AllowSorting="True"
                                          AllowFiltering="True"
                                          AllowGrouping="True"
                                          AllowResizingColumns="True"
                                          AllowDraggingColumns="True"
                                          ShowGroupDropArea="True"
                                          SelectionMode="Single"
                                          SelectionUnit="Row"
                                          GridLinesVisibility="Both"
                                          HeaderLinesVisibility="Both"
                                          RowHeight="34"
                                          HeaderRowHeight="38"
                                          GroupCaptionTextFormat="{}{Key}: {ItemsCount} Routes"
                                          ColumnSizer="Star"
                                          NavigationMode="Row"
                                          Background="{DynamicResource BusBuddy.Brush.DataGrid.Background}"
                                          AutomationProperties.Name="Routes Data Grid"
                                          ToolTip="Transportation routes management - Click headers to sort, drag to group">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="Route Name" 
                                                     MappingName="RouteName" 
                                                     Width="140"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"
                                                     ShowToolTip="True"/>
                            <syncfusion:GridTextColumn HeaderText="School" 
                                                     MappingName="School" 
                                                     Width="120"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"/>
                            <syncfusion:GridTextColumn HeaderText="Description" 
                                                     MappingName="Description" 
                                                     Width="200"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"
                                                     ShowToolTip="True"/>
                            <syncfusion:GridDateTimeColumn HeaderText="Date" 
                                                         MappingName="Date" 
                                                         Width="110" 
                                                         Pattern="ShortDate"
                                                         AllowSorting="True"
                                                         AllowFiltering="True"
                                                         DisplayBinding="{Binding Date, StringFormat='{}{0:MM/dd/yyyy}'}"/>
                        </syncfusion:SfDataGrid.Columns>
                        
                        <!-- Enhanced Summary Rows for Routes -->
                        <syncfusion:SfDataGrid.TableSummaryRows>
                            <syncfusion:GridTableSummaryRow Title="Total Routes: {TotalRoutes}" 
                                                          Position="Bottom" 
                                                          ShowSummaryInRow="True">
                                <syncfusion:GridTableSummaryRow.SummaryColumns>
                                    <syncfusion:GridSummaryColumn Name="TotalRoutes" 
                                                                Format="'{Count}'" 
                                                                MappingName="RouteName" 
                                                                SummaryType="CountAggregate"/>
                                </syncfusion:GridTableSummaryRow.SummaryColumns>
                            </syncfusion:GridTableSummaryRow>
                        </syncfusion:SfDataGrid.TableSummaryRows>
                    </syncfusion:SfDataGrid>

                    <!-- Enhanced Route Management Action Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,0">
                        <syncfusion:ButtonAdv Label="🗺️ Optimize Routes" 
                                              Margin="0,0,10,0" 
                                              Padding="14,8"
                                              Background="{DynamicResource BusBuddy.Brush.Primary}" 
                                              Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}" 
                                              BorderThickness="0"
                                              CornerRadius="4"
                                              Command="{Binding OptimizeRoutesCommand}"
                                              FontSize="13" 
                                              FontWeight="SemiBold"
                                              ToolTip="Optimize route efficiency and timing using advanced algorithms"
                                              AutomationProperties.Name="Optimize Transportation Routes"
                                              SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/optimize-icon.png"
                                              SizeMode="Normal"/>
                        <syncfusion:ButtonAdv Label="📄 Export Schedules" 
                                              Margin="0,0,10,0"
                                              Padding="14,8"
                                              Background="{DynamicResource BusBuddy.Brush.Success}" 
                                              Foreground="{DynamicResource BusBuddy.Brush.Text.Success}" 
                                              BorderThickness="0"
                                              CornerRadius="4"
                                              Command="{Binding ExportSchedulesCommand}"
                                              FontSize="13" 
                                              FontWeight="SemiBold"
                                              ToolTip="Export route schedules to Excel or PDF format"
                                              AutomationProperties.Name="Export Route Schedules"
                                              SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/export-icon.png"
                                              SizeMode="Normal"/>
                        <syncfusion:ButtonAdv Label="➕ Add Route" 
                                              Padding="14,8"
                                              Background="{DynamicResource BusBuddy.Brush.Accent}" 
                                              Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}" 
                                              BorderThickness="0"
                                              CornerRadius="4"
                                              Command="{Binding AddRouteCommand}"
                                              FontSize="13" 
                                              FontWeight="SemiBold"
                                              ToolTip="Create a new transportation route"
                                              AutomationProperties.Name="Add New Route"
                                              SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/add-icon.png"
                                              SizeMode="Normal"/>
                    </StackPanel>
                </Grid>
            </ContentControl>

            <!-- Enhanced Buses Document Panel with comprehensive Syncfusion configuration -->
            <ContentControl syncfusion:DockingManager.Header="🚐 Fleet Management"
                            syncfusion:DockingManager.State="Document"
                            syncfusion:DockingManager.CanClose="False"
                            syncfusion:DockingManager.CanFloat="True"
                            syncfusion:DockingManager.CanDock="True"
                            syncfusion:DockingManager.CaptionToolTip="Bus Fleet Management - Monitor, maintain, and manage all vehicles"
                            Background="{DynamicResource BusBuddy.Brush.Panel.Background}">
                <Grid Margin="15" Background="{DynamicResource BusBuddy.Brush.Panel.Content}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <syncfusion:SfDataGrid Grid.Row="0" x:Name="BusesGrid"
                                          ItemsSource="{Binding Buses}"
                                          AutoGenerateColumns="False"
                                          AllowEditing="False"
                                          AllowSorting="True"
                                          AllowFiltering="True"
                                          AllowGrouping="True"
                                          AllowResizingColumns="True"
                                          AllowDraggingColumns="True"
                                          ShowGroupDropArea="True"
                                          SelectionMode="Single"
                                          SelectionUnit="Row"
                                          GridLinesVisibility="Both"
                                          HeaderLinesVisibility="Both"
                                          RowHeight="36"
                                          HeaderRowHeight="38"
                                          GroupCaptionTextFormat="{}{Key}: {ItemsCount} Buses"
                                          ColumnSizer="Star"
                                          NavigationMode="Row"
                                          Background="{DynamicResource BusBuddy.Brush.DataGrid.Background}"
                                          AutomationProperties.Name="Buses Data Grid"
                                          ToolTip="Fleet management - Monitor all buses, maintenance status, and capacity">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="Bus #" 
                                                     MappingName="BusNumber" 
                                                     Width="100"
                                                     TextAlignment="Center"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"/>
                            <syncfusion:GridTextColumn HeaderText="License Plate" 
                                                     MappingName="LicenseNumber" 
                                                     Width="120"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"/>
                            <syncfusion:GridTextColumn HeaderText="Make" 
                                                     MappingName="Make" 
                                                     Width="90"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"/>
                            <syncfusion:GridTextColumn HeaderText="Model" 
                                                     MappingName="Model" 
                                                     Width="110"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"/>
                            <syncfusion:GridNumericColumn HeaderText="Year" 
                                                        MappingName="Year" 
                                                        Width="70"
                                                        TextAlignment="Center"
                                                        AllowSorting="True"
                                                        AllowFiltering="True"
                                                        NumberDecimalDigits="0"/>
                            <syncfusion:GridNumericColumn HeaderText="Capacity" 
                                                        MappingName="SeatingCapacity" 
                                                        Width="80"
                                                        TextAlignment="Center"
                                                        AllowSorting="True"
                                                        AllowFiltering="True"
                                                        NumberDecimalDigits="0"/>
                            <syncfusion:GridTextColumn HeaderText="Status" 
                                                     MappingName="Status" 
                                                     Width="100"
                                                     TextAlignment="Center"
                                                     AllowSorting="True"
                                                     AllowFiltering="True"/>
                        </syncfusion:SfDataGrid.Columns>
                        
                        <!-- Enhanced Summary Rows for Fleet -->
                        <syncfusion:SfDataGrid.TableSummaryRows>
                            <syncfusion:GridTableSummaryRow Title="Fleet Summary - Total Buses: {TotalBuses}, Total Capacity: {TotalCapacity}" 
                                                          Position="Bottom" 
                                                          ShowSummaryInRow="True">
                                <syncfusion:GridTableSummaryRow.SummaryColumns>
                                    <syncfusion:GridSummaryColumn Name="TotalBuses" 
                                                                Format="'{Count}'" 
                                                                MappingName="BusNumber" 
                                                                SummaryType="CountAggregate"/>
                                    <syncfusion:GridSummaryColumn Name="TotalCapacity" 
                                                                Format="'{Sum}'" 
                                                                MappingName="SeatingCapacity" 
                                                                SummaryType="SumAggregate"/>
                                </syncfusion:GridTableSummaryRow.SummaryColumns>
                            </syncfusion:GridTableSummaryRow>
                        </syncfusion:SfDataGrid.TableSummaryRows>
                    </syncfusion:SfDataGrid>

                    <!-- Enhanced Fleet Management Action Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,0">
                        <syncfusion:ButtonAdv Label="➕ Add Bus" 
                                              Margin="0,0,10,0" 
                                              Padding="14,8"
                                              Background="{DynamicResource BusBuddy.Brush.Primary}" 
                                              Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}" 
                                              BorderThickness="0"
                                              CornerRadius="4"
                                              Command="{Binding AddBusCommand}"
                                              FontSize="13" 
                                              FontWeight="SemiBold"
                                              ToolTip="Add a new bus to the fleet with detailed specifications"
                                              AutomationProperties.Name="Add New Bus"
                                              SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/bus-add-icon.png"
                                              SizeMode="Normal"/>
                        <syncfusion:ButtonAdv Label="🔧 Maintenance" 
                                              Margin="0,0,10,0" 
                                              Padding="14,8"
                                              Background="{DynamicResource BusBuddy.Brush.Warning}" 
                                              Foreground="{DynamicResource BusBuddy.Brush.Text.Warning}" 
                                              BorderThickness="0"
                                              CornerRadius="4"
                                              Command="{Binding MaintenanceCommand}"
                                              FontSize="13" 
                                              FontWeight="SemiBold"
                                              ToolTip="Schedule and track comprehensive bus maintenance operations"
                                              AutomationProperties.Name="Bus Maintenance"
                                              SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/maintenance-icon.png"
                                              SizeMode="Normal"/>
                        <syncfusion:ButtonAdv Label="📊 Fleet Report" 
                                              Padding="14,8"
                                              Background="{DynamicResource BusBuddy.Brush.Success}" 
                                              Foreground="{DynamicResource BusBuddy.Brush.Text.Success}" 
                                              BorderThickness="0"
                                              CornerRadius="4"
                                              Command="{Binding FleetReportCommand}"
                                              FontSize="13" 
                                              FontWeight="SemiBold"
                                              ToolTip="Generate comprehensive fleet performance and utilization reports"
                                              AutomationProperties.Name="Generate Fleet Report"
                                              SmallIcon="pack://application:,,,/BusBuddy.WPF;component/Resources/report-icon.png"
                                              SizeMode="Normal"/>
                    </StackPanel>
                        <syncfusion:ButtonAdv Label="📊 Fleet Status" Padding="12,6"
                                              Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource ButtonForegroundBrush}" BorderThickness="0"
                                              Command="{Binding FleetStatusCommand}"
                                              ToolTip="View current fleet status and availability"
                                              AutomationProperties.Name="Fleet Status Overview"/>
                    </StackPanel>
                </Grid>
            </ContentControl>

            <!-- Drivers Panel -->
            <ContentControl syncfusion:DockingManager.Header="👨‍✈️ Drivers"
                            syncfusion:DockingManager.State="Document"
                            Background="{DynamicResource BusBuddy.Brush.Panel.Background}">
                <Grid Margin="15" Background="{DynamicResource BusBuddy.Brush.Panel.Content}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <syncfusion:SfDataGrid Grid.Row="0" x:Name="DriversGrid"
                                          ItemsSource="{Binding Drivers}"
                                          AutoGenerateColumns="False"
                                          AllowEditing="False"
                                          AllowSorting="True"
                                          AllowFiltering="True"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Both"
                                          HeaderLinesVisibility="Both"
                                          Background="{DynamicResource BusBuddy.Brush.DataGrid.Background}"
                                          AutomationProperties.Name="Drivers Data Grid"
                                          ToolTip="List of all drivers and their information">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="Name" MappingName="DriverName" Width="150"/>
                            <syncfusion:GridTextColumn HeaderText="License Type" MappingName="DriversLicenceType" Width="120"/>
                            <syncfusion:GridMaskColumn HeaderText="Phone" MappingName="DriverPhone" Width="120" Mask="(###) ###-####"/>
                            <syncfusion:GridTextColumn HeaderText="Email" MappingName="DriverEmail" Width="200"/>
                        </syncfusion:SfDataGrid.Columns>
                    </syncfusion:SfDataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,0">
                        <syncfusion:ButtonAdv Label="➕ Add Driver" Margin="0,0,10,0" Padding="12,6"
                                              Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource ButtonForegroundBrush}" BorderThickness="0"
                                              Command="{Binding AddDriverCommand}"
                                              ToolTip="Add a new driver to the system"
                                              AutomationProperties.Name="Add New Driver"/>
                        <syncfusion:ButtonAdv Label="🚌 Assign Bus" Margin="0,0,10,0" Padding="12,6"
                                              Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource ButtonForegroundBrush}" BorderThickness="0"
                                              Command="{Binding AssignBusCommand}"
                                              ToolTip="Assign a bus to the selected driver"
                                              AutomationProperties.Name="Assign Bus to Driver"/>
                        <syncfusion:ButtonAdv Label="📅 Schedule" Padding="12,6"
                                              Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource ButtonForegroundBrush}" BorderThickness="0"
                                              Command="{Binding ScheduleCommand}"
                                              ToolTip="Manage driver schedules and assignments"
                                              AutomationProperties.Name="Driver Schedule Management"/>
                    </StackPanel>
                </Grid>
            </ContentControl>

            <!-- Map Panel (Google Earth Integration) -->
            <ContentControl x:Name="MapPane"
                            syncfusion:DockingManager.Header="🌍 Map"
                            syncfusion:DockingManager.State="Document"
                            Background="{DynamicResource BusBuddy.Brush.Panel.Background}">
                <Grid Background="{DynamicResource BusBuddy.Brush.Panel.Content}">
                    <viewsGE:GoogleEarthView />
                </Grid>
            </ContentControl>

            <!-- Route Assignment Panel -->
            <ContentControl syncfusion:DockingManager.Header="🗺️ Route Assignments"
                            syncfusion:DockingManager.State="Document"
                            Background="{DynamicResource BusBuddy.Brush.Panel.Background}">
                <Grid Background="{DynamicResource BusBuddy.Brush.Panel.Content}">
                    <route:RouteAssignmentView/>
                </Grid>
            </ContentControl>

        </syncfusion:DockingManager>

        <!-- =================================================================== -->
        <!-- STATUS BAR: System information and application status               -->
        <!-- =================================================================== -->
        
        <!-- 
            Status Bar Section: Displays application status and module readiness
            - High contrast design for accessibility
            - Dynamic theme support with separate brush resources
            - Module completion indicators
            - Demo readiness status
        -->
        <Border Grid.Row="2" Padding="15,12">
            <Border.Resources>
                <!-- 
                    Status Bar Color Resources: High-contrast theme-aware brushes
                    - Dark theme defaults with light theme fallbacks
                    - Ensures readability in both FluentDark and FluentLight themes
                    - Primary text for main status, accent text for highlights
                -->
                <!-- Dark theme status bar colors -->
                <!-- Dark theme status bar colors -->
                <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#12161C" />
                <SolidColorBrush x:Key="StatusBarPrimaryTextBrush" Color="#FFFFFF" />
                <SolidColorBrush x:Key="StatusBarAccentTextBrush" Color="#FACC15" />
                
                <!-- Light theme status bar colors -->
                <SolidColorBrush x:Key="StatusBarBackgroundBrushLight" Color="#F3F4F6" />
                <SolidColorBrush x:Key="StatusBarPrimaryTextBrushLight" Color="#111827" />
                <SolidColorBrush x:Key="StatusBarAccentTextBrushLight" Color="#065F46" />
            </Border.Resources>
            <!-- Dynamic theme styling: Switches between dark and light status bar colors -->
            <Border.Style>
                <Style TargetType="Border">
                    <!-- Default: Dark theme background -->
                    <Setter Property="Background" Value="{StaticResource StatusBarBackgroundBrush}" />
                    <Style.Triggers>
                        <!-- Light theme trigger: Switch to light colors when window background is white -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Background.(SolidColorBrush.Color)}" Value="#FFFFFFFF">
                            <Setter Property="Background" Value="{StaticResource StatusBarBackgroundBrushLight}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <!-- Status bar content: Two-column layout with status and readiness indicator -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Left side: Module completion status with checkmarks -->
                <TextBlock Grid.Column="0"
                           Text="🎯 Students ✅ | Routes ✅ | Buses ✅ | Drivers ✅ | Reports ✅"
                           Foreground="{StaticResource StatusBarPrimaryTextBrush}" VerticalAlignment="Center" FontSize="14" TextTrimming="CharacterEllipsis"/>
                
                <!-- Right side: Dynamic time-based greeting (bound to ViewModel) -->
                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentTimeGreeting}"
                           Foreground="{StaticResource StatusBarAccentTextBrush}" 
                           VerticalAlignment="Center" 
                           FontSize="14" 
                           FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</syncfusion:ChromelessWindow>

<!-- 
    End of MainWindow.xaml
    
    Summary of key features implemented:
    ✅ Professional ChromelessWindow with Syncfusion controls
    ✅ Dynamic theme switching (FluentDark/FluentLight)
    ✅ DockingManager layout with dockable panels and document tabs
    ✅ Students, Routes, Buses, and Drivers management modules
    ✅ Google Earth map integration
    ✅ PDF generation and printing capabilities
    ✅ Comprehensive data grids with sorting/filtering
    ✅ MVVM pattern with command binding throughout
    ✅ High-contrast status bar with module status indicators
    ✅ Accessibility features with AutomationProperties
    ✅ Responsive design with proper layout management
-->
