<UserControl x:Class="BusBuddy.WPF.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:syncfusiontools="clr-namespace:Syncfusion.Windows.Tools.Controls;assembly=Syncfusion.Tools.WPF">
    <Grid Background="{DynamicResource PrimaryBackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚙️ Application Settings"
                   FontSize="26" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="24">
            <StackPanel MaxWidth="520" HorizontalAlignment="Left">
                <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <syncfusion:ComboBoxAdv ItemsSource="{Binding AvailableThemes}"
                                        SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                        Width="220" Margin="0,0,0,20"/>

                <syncfusiontools:ToggleButtonExt Content="Enable activity logging"
                                             IsChecked="{Binding EnableActivityLogging, Mode=TwoWay}"
                                             Margin="0,0,0,12"/>
                <syncfusiontools:ToggleButtonExt Content="Show dashboard on startup"
                                             IsChecked="{Binding ShowDashboardOnStartup, Mode=TwoWay}"
                                             Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal">
                    <syncfusion:ButtonAdv Label="💾 Save" Command="{Binding SaveCommand}" Margin="0,0,10,0"/>
                    <syncfusion:ButtonAdv Label="↩️ Reset Defaults" Command="{Binding ResetCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,12,0,0"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>
    </Grid>
</UserControl>
