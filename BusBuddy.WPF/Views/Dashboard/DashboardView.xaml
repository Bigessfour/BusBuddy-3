<UserControl x:Class="BusBuddy.WPF.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
             xmlns:syncfusionchart="clr-namespace:Syncfusion.UI.Xaml.Charts;assembly=Syncfusion.SfChart.WPF"
             xmlns:syncfusionGauge="clr-namespace:Syncfusion.UI.Xaml.Gauges;assembly=Syncfusion.SfGauge.WPF"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=FluentDark}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Dashboard-specific resources -->
        <SolidColorBrush x:Key="BusBuddy.Brush.Tile.Header" Color="#2D3748"/>
        <SolidColorBrush x:Key="BusBuddy.Brush.Text.Muted" Color="#718096"/>
        <SolidColorBrush x:Key="BusBuddy.Brush.Control.Text" Color="#4A5568"/>
        <SolidColorBrush x:Key="BusBuddy.Brush.Status.Loading" Color="#3182CE"/>
        <SolidColorBrush x:Key="BusBuddy.Brush.Semantic.Success" Color="#38A169"/>
        <SolidColorBrush x:Key="BusBuddy.Brush.Semantic.Error" Color="#E53E3E"/>
        <SolidColorBrush x:Key="BusBuddy.Brush.Priority.Critical" Color="#E53E3E"/>
        <SolidColorBrush x:Key="BusBuddy.Brush.Priority.High" Color="#DD6B20"/>
        <SolidColorBrush x:Key="BusBuddy.Brush.Priority.Medium" Color="#D69E2E"/>
        <SolidColorBrush x:Key="BusBuddy.Brush.Priority.Low" Color="#38A169"/>
        <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#2D3748"/>
        <SolidColorBrush x:Key="AccentTextBrush" Color="#3182CE"/>

        <!-- Tile content template -->
        <DataTemplate x:Key="TileContentTemplate">
            <TextBlock Text="{Binding}"
                      FontSize="24" FontWeight="Bold"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Foreground="{DynamicResource BusBuddy.Brush.Tile.Header}"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dashboard Header -->
        <Border Grid.Row="0" CornerRadius="8" Padding="20,15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🚌 BusBuddy Dashboard"
                               FontSize="28" FontWeight="Bold"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Transportation Management Overview"
                               FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Use Syncfusion ButtonAdv with default theming -->
                    <syncfusion:ButtonAdv Label="🔄 Refresh"
                                          Command="{Binding RefreshCommand}"
                                          Margin="0,0,10,0" Padding="15,8"
                                          AutomationProperties.Name="Refresh Dashboard"
                                          AutomationProperties.HelpText="Reload dashboard metrics and lists"/>
                    <syncfusion:ButtonAdv Label="📊 Report"
                                          Command="{Binding GenerateReportCommand}"
                                          Padding="15,8"
                                          AutomationProperties.Name="Generate Dashboard Report"
                                          AutomationProperties.HelpText="Generate printable dashboard report"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Key Metrics Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Routes Card -->
            <Border Grid.Column="0" Margin="0,0,10,0" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🗺️" FontSize="24"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Text="{Binding TotalRoutes}"
                               FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Text="Total Routes"
                               FontSize="12" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </Grid>
            </Border>

            <!-- Active Buses Card -->
            <Border Grid.Column="1" Margin="5,0" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🚌" FontSize="24"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Text="{Binding ActiveBuses}"
                               FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Text="Active Buses"
                               FontSize="12" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </Grid>
            </Border>

            <!-- Available Drivers Card -->
            <Border Grid.Column="2" Margin="5,0" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="👨‍✈️" FontSize="24"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Text="{Binding AvailableDrivers}"
                               FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Text="Available Drivers"
                               FontSize="12" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </Grid>
            </Border>

            <!-- System Status Gauge Card -->
            <Border Grid.Column="3" Margin="10,0,0,0" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📊 System Health"
                               FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <syncfusionGauge:SfCircularGauge Grid.Row="1" 
                                                     x:Name="SystemHealthGauge"
                                                     Height="60" Width="60">
                        <syncfusionGauge:SfCircularGauge.Scales>
                            <syncfusionGauge:CircularScale StartAngle="180" 
                                                          SweepAngle="180"
                                                          StartValue="0" 
                                                          EndValue="100"
                                                          Interval="20"
                                                          ShowLabels="False"
                                                          ShowTicks="False">
                                <syncfusionGauge:CircularScale.Pointers>
                                    <syncfusionGauge:CircularPointer Value="{Binding FleetUtilization}" 
                                                                   PointerType="NeedlePointer"/>
                                </syncfusionGauge:CircularScale.Pointers>
                                <syncfusionGauge:CircularScale.Ranges>
                                    <syncfusionGauge:CircularRange StartValue="0" EndValue="60" 
                                                                  Background="#FFE53E3E"/>
                                    <syncfusionGauge:CircularRange StartValue="60" EndValue="80" 
                                                                  Background="#FFFF9800"/>
                                    <syncfusionGauge:CircularRange StartValue="80" EndValue="100" 
                                                                  Background="#FF4CAF50"/>
                                </syncfusionGauge:CircularScale.Ranges>
                            </syncfusionGauge:CircularScale>
                        </syncfusionGauge:SfCircularGauge.Scales>
                    </syncfusionGauge:SfCircularGauge>
                    <TextBlock Grid.Row="2" Text="{Binding FleetUtilization, StringFormat='Fleet: {0:F0}%'}"
                               FontSize="10" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Main Content Area with Syncfusion DockingManager (aligns with MainWindow pattern) -->
        <syncfusion:DockingManager Grid.Row="2"
                                   x:Name="DashboardDockingManager"
                                   UseDocumentContainer="True"
                                   PersistState="True">
            <!-- Recent Routes - docked on the left -->
            <ContentControl x:Name="RecentRoutesPane"
                            syncfusion:DockingManager.Header="📋 Recent Routes"
                            syncfusion:DockingManager.State="Dock"
                            syncfusion:DockingManager.SideInDockedMode="Left"
                            syncfusion:DockingManager.DesiredWidthInDockedMode="450">
                <Border CornerRadius="8" Margin="0,0,10,0">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📋 Recent Routes"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="📋 Recent Routes"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,10" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Routes.Count, StringFormat='Total Routes: {0}'}"
                                           FontSize="12" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </ContentControl>

            <!-- Fleet Status - docked on the right -->
            <ContentControl x:Name="FleetStatusPane"
                            syncfusion:DockingManager.Header="🚌 Fleet Status"
                            syncfusion:DockingManager.State="Dock"
                            syncfusion:DockingManager.SideInDockedMode="Right"
                            syncfusion:DockingManager.DesiredWidthInDockedMode="520">
                <Border CornerRadius="8" Margin="10,0,0,0">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="🚌 Fleet Status"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="🚌 Fleet Data Loading..."
                                           FontSize="14" 
                                           Margin="0,10" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Buses.Count, StringFormat='Total Buses: {0}'}"
                                           FontSize="12" 
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ActiveBuses, StringFormat='Active: {0}'}"
                                           FontSize="12" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </ContentControl>

            <!-- Enhanced Dashboard Central Document with TileViewControl (Syncfusion 30.2.6) -->
            <ContentControl x:Name="DashboardDocument"
                            syncfusion:DockingManager.Header="📈 Dashboard Analytics"
                            syncfusion:DockingManager.State="Document">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header Section with Performance Controls -->
                    <Border Grid.Row="0" CornerRadius="6" Margin="0,0,0,15" Padding="15,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="📊 Analytics Tiles"
                                          FontSize="16" FontWeight="SemiBold"
                                          VerticalAlignment="Center"
                                          Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding DashboardTiles.Count, StringFormat='({0} active tiles)'}"
                                          FontSize="12"
                                          VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <syncfusion:ButtonAdv Label="🔄 Refresh All"
                                                     Command="{Binding RefreshCommand}"
                                                     Padding="10,6"
                                                     Margin="0,0,8,0"
                                                     FontSize="12"
                                                     ToolTip="Refresh all dashboard tiles"/>
                                
                                <syncfusion:ButtonAdv Label="⚙️ Layout"
                                                     Command="{Binding RefreshCommand}"
                                                     Padding="10,6"
                                                     FontSize="12"
                                                     ToolTip="Reset tile layout to default"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Enhanced TileViewControl with Performance Optimization -->
                    <ItemsControl Grid.Row="1"
                                  x:Name="DashboardTileView"
                                  ItemsSource="{Binding DashboardTiles}"
                                  Padding="10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12" Margin="5" Width="160" Height="120">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Tile Header with Priority Indicator -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                      Text="{Binding Title}"
                                                      FontSize="14" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource BusBuddy.Brush.Tile.Header}"
                                                      TextTrimming="CharacterEllipsis"/>

                                            <Border Grid.Column="1"
                                                   Width="6" Height="6"
                                                   CornerRadius="3"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Priority.Low}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Priority}" Value="2">
                                                                <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Priority.High}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Priority}" Value="3">
                                                                <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Priority.Critical}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>

                                        <!-- Tile Content -->
                                        <ContentPresenter Grid.Row="1"
                                                         Content="{Binding Content}"
                                                         ContentTemplate="{StaticResource TileContentTemplate}"
                                                         VerticalAlignment="Stretch"
                                                         HorizontalAlignment="Stretch"/>

                                        <!-- Tile Footer -->
                                        <Grid Grid.Row="2" Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                      Text="{Binding LastUpdatedFormatted}"
                                                      FontSize="10"
                                                      Foreground="{DynamicResource BusBuddy.Brush.Text.Muted}"
                                                      VerticalAlignment="Center"/>

                                            <syncfusion:ButtonAdv Grid.Column="1"
                                                                 Label="↻"
                                                                 Command="{Binding RefreshCommand}"
                                                                 Width="20" Height="20"
                                                                 Padding="2"
                                                                 Background="Transparent"
                                                                 Foreground="{DynamicResource BusBuddy.Brush.Control.Text}"
                                                                 BorderThickness="0"
                                                                 FontSize="10"
                                                                 ToolTip="Refresh tile data"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ContentControl>

            <!-- Route Capacity Chart - docked on the bottom -->
            <ContentControl x:Name="RouteChartPane"
                            syncfusion:DockingManager.Header="📊 Route Capacity Chart"
                            syncfusion:DockingManager.State="Dock"
                            syncfusion:DockingManager.SideInDockedMode="Bottom"
                            syncfusion:DockingManager.DesiredHeightInDockedMode="300">
                <Border CornerRadius="8" Margin="0,10,0,0">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📊 Route Capacity Analysis"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <syncfusionchart:SfChart Grid.Row="1"
                                                 x:Name="RouteCapacityChart"
                                                 AreaBorderThickness="0,1,0,0">
                            <syncfusionchart:SfChart.PrimaryAxis>
                                <syncfusionchart:CategoryAxis Header="Routes"
                                                              FontSize="12"
                                                              LabelRotationAngle="-45"/>
                            </syncfusionchart:SfChart.PrimaryAxis>
                            <syncfusionchart:SfChart.SecondaryAxis>
                                <syncfusionchart:NumericalAxis Header="Capacity/Assigned"
                                                               FontSize="12"/>
                            </syncfusionchart:SfChart.SecondaryAxis>
                            <syncfusionchart:ColumnSeries x:Name="CapacitySeries"
                                                          ItemsSource="{Binding RouteCapacities}"
                                                          XBindingPath="RouteName"
                                                          YBindingPath="Capacity"
                                                          Label="Capacity">
                                <syncfusionchart:ColumnSeries.AdornmentsInfo>
                                    <syncfusionchart:ChartAdornmentInfo ShowLabel="True"/>
                                </syncfusionchart:ColumnSeries.AdornmentsInfo>
                            </syncfusionchart:ColumnSeries>
                            <syncfusionchart:ColumnSeries x:Name="AssignedSeries"
                                                          ItemsSource="{Binding RouteCapacities}"
                                                          XBindingPath="RouteName"
                                                          YBindingPath="Assigned"
                                                          Label="Assigned">
                                <syncfusionchart:ColumnSeries.AdornmentsInfo>
                                    <syncfusionchart:ChartAdornmentInfo ShowLabel="True"/>
                                </syncfusionchart:ColumnSeries.AdornmentsInfo>
                            </syncfusionchart:ColumnSeries>
                        </syncfusionchart:SfChart>
                    </Grid>
                </Border>
            </ContentControl>

            <!-- Upcoming Events Scheduler - document tab -->
            <ContentControl x:Name="SchedulerDocument"
                            syncfusion:DockingManager.Header="📅 Upcoming Events"
                            syncfusion:DockingManager.State="Document">
                <Border CornerRadius="8" Margin="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📅 Event Schedule"
                                  FontSize="16" FontWeight="SemiBold"
                                  Margin="0,0,0,15"/>

                        <ListView Grid.Row="1" 
                                  ItemsSource="{Binding UpcomingEvents}"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="10" Margin="0,2" Background="{DynamicResource ContentBackgroundBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding EventName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding StartTime, StringFormat='{}{0:MMM dd, yyyy HH:mm}'}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <TextBlock Text="{Binding Location}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" 
                                                      FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </ContentControl>
        </syncfusion:DockingManager>

        <!-- Status Bar -->
    <Border Grid.Row="3" Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="8"
                Padding="20,12" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding SystemStatus}"
                           Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" FontSize="14"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource BusBuddy.Brush.Semantic.Success}" Margin="0,0,8,0"/>
                    <TextBlock Text="Last Updated: Now"
                               Foreground="{DynamicResource BusBuddy.Brush.Semantic.Success}" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
    <Border Grid.RowSpan="4" Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                CornerRadius="8">
            <Grid>
                <TextBlock Text="⏳" FontSize="60"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
               Foreground="{DynamicResource AccentTextBrush}"/>
                <TextBlock Text="Loading dashboard data..."
               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,100,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
