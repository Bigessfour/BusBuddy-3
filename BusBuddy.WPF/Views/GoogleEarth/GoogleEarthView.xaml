<!--
    ===============================================
    GOOGLE EARTH INTEGRATION VIEW - PRODUCTION READY
    ===============================================
    Comprehensive geospatial mapping and route visualization using Syncfusion WPF 30.2.9
    
    ARCHITECTURE OVERVIEW:
    • Main View: UserControl with MVVM pattern (GoogleEarthViewModel)
    • Map Engine: Syncfusion SfMap with multi-layer support and advanced overlays
    • Theme Support: Full FluentDark/FluentLight theming with dynamic resource binding
    • Real-time Features: Live GPS tracking, route optimization, boundary visualization
    • Export Capabilities: PDF generation with embedded map snapshots
    
    SYNCFUSION CONTROLS USED (30.2.9):
    • SfMap - Primary mapping control with layer management
    • ButtonAdv - Enhanced buttons with professional styling and interaction states
    • ComboBoxAdv - Layer selection with theme-aware dropdown styling
    • SfBusyIndicator - Loading states with smooth animations
    • SfDataGrid - Route and bus data management with advanced features
    
    All controls use dynamic resource references for theme-aware styling.
    Reference: https://help.syncfusion.com/wpf/maps/overview
-->
<UserControl x:Class="BusBuddy.WPF.Views.GoogleEarth.GoogleEarthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:maps="clr-namespace:Syncfusion.UI.Xaml.Maps;assembly=Syncfusion.SfMaps.WPF"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BusBuddy.WPF.Views.GoogleEarth"
             xmlns:viewModels="clr-namespace:BusBuddy.WPF.ViewModels.GoogleEarth"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance viewModels:GoogleEarthViewModel}">

    <UserControl.Resources>
        <!-- Framework converter for visibility binding -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Professional Header Icon Style with dynamic resources -->
        <Style x:Key="HeaderIconStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Accent}"/>
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
        </Style>
        
        <!-- Enhanced Status Indicator Style with dynamic resources -->
        <Style x:Key="StatusIndicatorStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Button.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BusBuddy.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="8,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Accent}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BusBuddy.Brush.Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Control Panel Section Style with dynamic resources -->
        <Style x:Key="ControlPanelSectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Panel.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BusBuddy.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        
        <!-- Professional Button Style with dynamic resources -->
        <Style x:Key="ProfessionalButtonStyle" TargetType="syncfusion:ButtonAdv">
            <Setter Property="Background" Value="{DynamicResource BusBuddy.Brush.Button.Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource BusBuddy.Brush.Button.Foreground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <!-- Main Layout Grid -->
    <Grid Background="{DynamicResource BusBuddy.Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0"
                Background="{DynamicResource BusBuddy.Brush.Accent}"
                Padding="32,20"
                BorderBrush="{DynamicResource BusBuddy.Brush.Border}"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Header: Branding and Title -->
                <StackPanel Grid.Column="0" 
                           Orientation="Horizontal" 
                           VerticalAlignment="Center">
                    <Border Style="{StaticResource HeaderIconStyle}">
                        <TextBlock Text="🌍"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Google Earth Integration"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}"
                                   AutomationProperties.Name="Google Earth Integration Title"/>
                        <TextBlock Text="Advanced Geospatial Mapping • Route Visualization • Fleet Tracking"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                   Margin="0,6,0,0"
                                   Opacity="0.9"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right Header: Status and Controls -->
                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal" 
                           VerticalAlignment="Center">
                    <Border Style="{StaticResource StatusIndicatorStyle}"
                            ToolTip="GPS connectivity status - Real-time positioning active"
                            AutomationProperties.Name="GPS Status Indicator">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="12" Height="12"
                                    Fill="{DynamicResource BusBuddy.Brush.Success}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"/>
                            <TextBlock Text="GPS Active"
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Map Layer Selector using Syncfusion ComboBoxAdv with dynamic resources -->
                    <syncfusion:ComboBoxAdv x:Name="MapLayerComboBox"
                                            Width="180"
                                            Height="40"
                                            Margin="20,0,0,0"
                                            SelectedIndex="0"
                                            SelectionChanged="MapLayerComboBox_SelectionChanged"
                                            Background="{DynamicResource BusBuddy.Brush.Panel.Background}"
                                            BorderBrush="{DynamicResource BusBuddy.Brush.Border}"
                                            BorderThickness="2"
                                            Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                            MaxDropDownHeight="300"
                                            IsEditable="False"
                                            AllowMultiSelect="False"
                                            VerticalContentAlignment="Center"
                                            Padding="16,0"
                                            FontSize="14"
                                            FontWeight="Medium"
                                            ToolTip="Select map layer type for optimal route visualization"
                                            AutomationProperties.Name="Map Layer Selector">
                        <syncfusion:ComboBoxItemAdv Content="🛰️ Satellite View" Tag="Satellite"/>
                        <syncfusion:ComboBoxItemAdv Content="🗺️ Terrain View" Tag="Terrain"/>
                        <syncfusion:ComboBoxItemAdv Content="🌐 Hybrid View" Tag="Hybrid"/>
                        <syncfusion:ComboBoxItemAdv Content="🛣️ Roadmap View" Tag="Roadmap"/>
                        <syncfusion:ComboBoxItemAdv Content="🌍 OpenStreetMap" Tag="OpenStreetMap"/>
                    </syncfusion:ComboBoxAdv>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="280"/>
                <ColumnDefinition Width="*" MinWidth="600"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Control Panel -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BusBuddy.Brush.Panel.Background}"
                    BorderBrush="{DynamicResource BusBuddy.Brush.Border}"
                    BorderThickness="2"
                    CornerRadius="8,0,0,8"
                    Padding="4">
                
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="20"
                              Background="Transparent">
                    
                    <StackPanel>
                        
                        <!-- Map Control Section -->
                        <Border Style="{StaticResource ControlPanelSectionStyle}">
                            <StackPanel>
                                <TextBlock Text="🗺️ Map Navigation"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}"
                                           Margin="0,0,0,16"
                                           AutomationProperties.Name="Map Navigation Controls Section"/>

                                <syncfusion:ButtonAdv Label="📍 Center on Fleet"
                                                      Command="{Binding CenterOnFleetCommand}"
                                                      Style="{StaticResource ProfessionalButtonStyle}"
                                                      ToolTip="Center map view on entire fleet location"
                                                      AutomationProperties.Name="Center Map on Fleet"/>

                                <syncfusion:ButtonAdv Label="🚌 Show All Buses"
                                                      Command="{Binding ShowAllBusesCommand}"
                                                      Style="{StaticResource ProfessionalButtonStyle}"
                                                      ToolTip="Display all active buses with real-time positioning"
                                                      AutomationProperties.Name="Show All Active Buses"/>

                                <syncfusion:ButtonAdv Label="🛣️ Show Routes"
                                                      Command="{Binding ShowRoutesCommand}"
                                                      Style="{StaticResource ProfessionalButtonStyle}"
                                                      ToolTip="Overlay all transportation routes with detailed paths"
                                                      AutomationProperties.Name="Show All Transportation Routes"/>

                                <syncfusion:ButtonAdv Label="🏫 Show Schools"
                                                      Command="{Binding ShowSchoolsCommand}"
                                                      Style="{StaticResource ProfessionalButtonStyle}"
                                                      ToolTip="Display all school locations with zone boundaries"
                                                      AutomationProperties.Name="Show All School Locations"/>
                            </StackPanel>
                        </Border>

                        <!-- Overlay Controls Section -->
                        <Border Style="{StaticResource ControlPanelSectionStyle}">
                            <StackPanel>
                                <TextBlock Text="🎯 Map Overlays"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}"
                                           Margin="0,0,0,16"
                                           AutomationProperties.Name="Map Overlay Controls Section"/>

                                <CheckBox x:Name="DistrictBoundaryToggle" 
                                          Content="🏛️ District Boundaries"
                                          IsChecked="{Binding IsDistrictBoundaryVisible, Mode=TwoWay}"
                                          Margin="0,0,0,12"
                                          FontSize="14"
                                          FontWeight="Medium"
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                          ToolTip="Toggle school district boundary overlay"
                                          AutomationProperties.Name="District Boundary Toggle"/>

                                <CheckBox x:Name="TownBoundaryToggle" 
                                          Content="🏘️ Town Limits"
                                          IsChecked="{Binding IsTownBoundaryVisible, Mode=TwoWay}"
                                          Margin="0,0,0,12"
                                          FontSize="14"
                                          FontWeight="Medium"
                                          Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                          ToolTip="Toggle town/city boundary overlay"
                                          AutomationProperties.Name="Town Boundary Toggle"/>

                                <syncfusion:ButtonAdv Label="➕ Add Demo Stop"
                                                      Command="{Binding AddMarkerCommand}"
                                                      CommandParameter="38.1530,-102.7200,Demo Stop"
                                                      Style="{StaticResource ProfessionalButtonStyle}"
                                                      ToolTip="Add demonstration stop marker near Wiley"
                                                      AutomationProperties.Name="Add Demonstration Stop Marker"/>
                            </StackPanel>
                        </Border>

                        <!-- Active Buses Section using SfDataGrid -->
                        <Border Style="{StaticResource ControlPanelSectionStyle}">
                            <StackPanel>
                                <TextBlock Text="Active Buses"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BusBuddy.Brush.Text.Primary}"
                                           Margin="0,0,0,12"/>

                                <syncfusion:SfDataGrid x:Name="BusListGrid"
                                                       ItemsSource="{Binding ActiveBuses}"
                                                       SelectedItem="{Binding SelectedBus}"
                                                       Height="200"
                                                       AutoGenerateColumns="False"
                                                       AllowEditing="False"
                                                       AllowSorting="True"
                                                       AllowFiltering="False"
                                                       SelectionMode="Single"
                                                       GridLinesVisibility="Both"
                                                       HeaderLinesVisibility="Both"
                                                       Background="{DynamicResource BusBuddy.Brush.DataGrid.Background}">
                                    <syncfusion:SfDataGrid.Columns>
                                        <syncfusion:GridTextColumn HeaderText="Bus #"
                                                                   MappingName="BusNumber"
                                                                   Width="60"/>
                                        <syncfusion:GridTextColumn HeaderText="Route"
                                                                   MappingName="RouteNumber"
                                                                   Width="60"/>
                                        <syncfusion:GridTextColumn HeaderText="Status"
                                                                   MappingName="Status"
                                                                   Width="80"/>
                                    </syncfusion:SfDataGrid.Columns>
                                </syncfusion:SfDataGrid>

                                <syncfusion:ButtonAdv Content="📍 Track Selected"
                                                      Command="{Binding TrackSelectedBusCommand}"
                                                      Style="{StaticResource ProfessionalButtonStyle}"
                                                      Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Panel: Map Display Area -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BusBuddy.Brush.Panel.Background}"
                    BorderBrush="{DynamicResource BusBuddy.Brush.Border}"
                    BorderThickness="1"
                    Margin="0"
                    MinHeight="400">
                <Grid>
                    <!-- SfMap Control using Syncfusion Maps 30.2.9 -->
                    <Border x:Name="MapContainer"
                            Background="{DynamicResource BusBuddy.Brush.Content.Background}"
                            CornerRadius="8"
                            Margin="16"
                            MinHeight="400">
                        <Grid>
                            <!-- SfMap - Primary mapping control per Syncfusion docs -->
                            <maps:SfMap x:Name="GeoMap"
                                        EnableZoom="True"
                                        EnablePan="True"
                                        Background="{DynamicResource BusBuddy.Brush.Content.Background}"/>

                            <!-- Map Loading Indicator using SfBusyIndicator -->
                            <Border x:Name="MapLoadingIndicator"
                                    Background="{DynamicResource BusBuddy.Brush.Accent}"
                                    Opacity="0.95"
                                    Visibility="{Binding IsMapLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <syncfusion:SfBusyIndicator Grid.Row="0"
                                                               Width="80" Height="80"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               AnimationType="Flight"/>
                                    <TextBlock Grid.Row="1"
                                               Text="Loading Map..."
                                               Margin="0,12,0,0"
                                               FontSize="16"
                                               Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Map Overlay Controls with dynamic resources -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="32,32,32,0">
                        <syncfusion:ButtonAdv Content="+"
                                              Command="{Binding ZoomInCommand}"
                                              Background="{DynamicResource BusBuddy.Brush.Button.Background}"
                                              Foreground="{DynamicResource BusBuddy.Brush.Button.Foreground}"
                                              Width="40" Height="40"
                                              FontSize="20"
                                              FontWeight="Bold"
                                              Margin="4,0"/>
                        <syncfusion:ButtonAdv Content="-"
                                              Command="{Binding ZoomOutCommand}"
                                              Background="{DynamicResource BusBuddy.Brush.Button.Background}"
                                              Foreground="{DynamicResource BusBuddy.Brush.Button.Foreground}"
                                              Width="40" Height="40"
                                              FontSize="20"
                                              FontWeight="Bold"
                                              Margin="4,0"/>
                        <syncfusion:ButtonAdv Content="🏠"
                                              Command="{Binding ResetViewCommand}"
                                              Background="{DynamicResource BusBuddy.Brush.Button.Background}"
                                              Foreground="{DynamicResource BusBuddy.Brush.Button.Foreground}"
                                              Width="40" Height="40"
                                              Margin="4,0"/>
                    </StackPanel>

                    <!-- OSM Attribution -->
                    <Border x:Name="OsmAttribution"
                            Background="{DynamicResource BusBuddy.Brush.Accent}"
                            Opacity="0.85"
                            CornerRadius="4"
                            Padding="6,2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,24,16"
                            Visibility="Collapsed">
                        <TextBlock Text="© OpenStreetMap contributors"
                                   FontSize="11"
                                   Foreground="{DynamicResource BusBuddy.Brush.Text.Accent}"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
