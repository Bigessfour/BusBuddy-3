{
  "environment": {
    "development": {
      "XAI_API_KEY": "${XAI_API_KEY}",
      "GROK_MODEL": "grok-4-0709",
      "GROK_MAX_TOKENS": 1200,
      "GROK_TEMPERATURE": 0.6,
      "LOG_LEVEL": "debug"
    },
    "production": {
      "XAI_API_KEY": "${XAI_API_KEY}",
      "GROK_MODEL": "grok-4-0709", 
      "GROK_MAX_TOKENS": 800,
      "GROK_TEMPERATURE": 0.4,
      "LOG_LEVEL": "info"
    }
  },
  "api_endpoints": {
    "xai": "https://api.x.ai/v1/chat/completions",
    "github": "https://api.github.com",
    "azure": "https://management.azure.com"
  },
  "rate_limits": {
    "xai_requests_per_minute": 480,
    "xai_tokens_per_minute": 256000,
    "github_requests_per_hour": 5000
  },
  "server_ports": {
    "grok4_mcp": "stdio",
    "busbuddy_mcp": "stdio", 
    "git_mcp": "stdio"
  }
}
