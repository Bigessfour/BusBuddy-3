{
  "mcpServers": {
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/stephenmckitrick/BusBuddy/BusBuddy-3"
      ],
      "command": "npx"
    },
    "brave-search": {
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": ""
      },
      "command": "npx"
    },
    "syncfusion-wpf-assistant": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@syncfusion/wpf-assistant@latest"
      ],
      "env": {
        "Syncfusion_API_Key": "YOUR_SYNCFUSION_API_KEY_HERE"
      }
    },
    "busbuddy-rag": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "rag.mcp_server"],
      "env": {}
    }
  }
