{
  "servers": {
    "azure-mcp": {
      "command": "npx",
      "args": ["-y", "@azure/mcp-server-azure"],
      "env": {
        "AZURE_CLIENT_ID": "860af3d3-df7a-4c76-915a-a6f980bd86ed",
        "AZURE_TENANT_ID": "3ee44d11-b5ae-43a0-9c02-004b04858d9e",
        "AZURE_SUBSCRIPTION_ID": "57b297a5-44cf-4abc-9ac4-91a5ed147de1"
      }
    },
    "github-mcp": {
      "command": "npx",
      "args": ["-y", "@github/mcp-server"],
      "env": {
        "GITHUB_API_URL": "https://api.github.com"
      }
    },
    "busbuddy-filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "c:\\Users\\biges\\Desktop\\BusBuddy"
      ]
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "BSAKWu26BLu4KPdKvzX_QjMqL87KtHr",
        "MCP_SEARCH_CONTEXT": "Expert in Syncfusion WPF Controls, APIs, and Documentation. Focus on providing accurate information about Syncfusion Essential Studio for WPF, including SfDataGrid, DockingManager, NavigationDrawer, SfChart, and related controls. Reference official Syncfusion documentation and best practices.",
        "MCP_SEARCH_DOMAIN_FOCUS": "help.syncfusion.com wpf controls api documentation"
      }
    },
    "microsoft-doc": {
      "command": "npx",
      "args": ["-y", "@microsoft/mcp-server-docs"]
    },
    "busbuddy-git": {
      "command": "node",
      "args": [
        "c:\\Users\\biges\\Desktop\\BusBuddy\\mcp\\servers\\git-mcp-server.js"
      ]
    },
    "busbuddy-project": {
      "command": "node",
      "args": [
        "c:\\Users\\biges\\Desktop\\BusBuddy\\mcp\\servers\\busbuddy-mcp-server.js"
      ],
      "env": {
        "BUSBUDDY_PROJECT_ROOT": "c:\\Users\\biges\\Desktop\\BusBuddy",
        "BUSBUDDY_DB_PATH": "c:\\Users\\biges\\Desktop\\BusBuddy\\BusBuddy.db"
      }
    },
    "busbuddy-grok-ai": {
      "type": "stdio",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "c:\\Users\\biges\\Desktop\\BusBuddy\\mcp\\servers\\BusBuddy.Grok.MCP.Server"
      ],
      "env": {
        "XAI_API_KEY": "${XAI_API_KEY}",
        "BUSBUDDY_PROJECT_ROOT": "c:\\Users\\biges\\Desktop\\BusBuddy",
        "XAI:DefaultModel": "grok-4-0709",
        "XAI:Temperature": "0.3",
        "XAI:UseLiveAPI": "true"
      }
    },
    "busbuddy-grok4-mcp": {
      "command": "node",
      "args": [
        "c:\\Users\\biges\\Desktop\\BusBuddy\\mcp\\servers\\grok4-mcp-server.js"
      ],
      "env": {
        "XAI_API_KEY": "${XAI_API_KEY}",
        "BUSBUDDY_PROJECT_ROOT": "c:\\Users\\biges\\Desktop\\BusBuddy",
        "NODE_ENV": "production"
      }
    }
  }
}
