{
  "version": "2.0.0",
  "tasks": [
    // === ENVIRONMENT SETUP ===
    {
      "label": "Load Environment Variables",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-File",
        "${workspaceFolder}/tools/scripts/Load-MCPEnvironment.ps1"
      ],
      "options": {
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": [],
      "group": "build"
    },
    // === BUILD TASKS ===
    {
      "type": "process",
      "label": "dotnet build BusBuddy.sln",
      "command": "dotnet",
      "args": ["build", "BusBuddy.sln", "--configuration", "Debug"],
      "options": {
        "env": {
          "BUSBUDDY_NO_WELCOME": "1",
          "BUSBUDDY_NO_XAI_WARN": "1",
          "BUSBUDDY_SILENT": "1",
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
        }
      },
      "problemMatcher": ["$msCompile"],
      "group": "build"
    },
    {
      "label": "bb-build (dotnet build BusBuddy.sln)",
      "type": "shell",
      "command": "dotnet",
      "args": ["build", "BusBuddy.sln", "-v", "m"],
      "options": {
        "env": {
          "BUSBUDDY_NO_WELCOME": "1",
          "BUSBUDDY_NO_XAI_WARN": "1",
          "BUSBUDDY_SILENT": "1",
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
        }
      },
      "problemMatcher": ["$msCompile"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build seeder only",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "c:\\Users\\biges\\Desktop\\BusBuddy\\TestDataSeeding\\TestDataSeeding.csproj",
        "-v",
        "m"
      ],
      "options": {
        "env": {
          "BUSBUDDY_NO_WELCOME": "1",
          "BUSBUDDY_NO_XAI_WARN": "1",
          "BUSBUDDY_SILENT": "1",
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
        }
      },
      "problemMatcher": ["$msCompile"],
      "group": "build"
    },
    {
      "label": "bb-wpf-build (C# WPF via PowerShell)",
      "type": "shell",
      "command": "bb-build",
      "problemMatcher": ["$msCompile"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },

    // === BUSBUDDY POWERSHELL PROFILE TASKS ===
    {
      "label": "bb-run (PowerShell Profile)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-Command", "bb-run"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "env": {
          "BUSBUDDY_NO_WELCOME": "1"
        }
      }
    },
    {
      "label": "bb-health (System Health Check)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-Command", "bb-health"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "bb-sql-test (SQL Database Test)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-Command", "bb-sql-test"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "bb-deps-check",
      "type": "shell",
      "command": "pwsh",
      "args": ["-Command", "bb-deps-check"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    // === CODE QUALITY & TRUNK TASKS ===
    {
      "label": "Trunk Check All",
      "type": "shell",
      "command": "trunk",
      "args": ["check", "--all", "--fix"],
      "dependsOn": ["Restore NuGet Packages"],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "trunk",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error|info):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },
    {
      "label": "Trunk Format All",
      "type": "shell",
      "command": "trunk",
      "args": ["fmt", "--all"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "bb-quality-check (BusBuddy Quality Gate)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-Command", "bb-quality-check"],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "trunk",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error|info):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },
    {
      "label": "bb-format-code (BusBuddy Code Formatting)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-Command", "bb-format-code"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "bb-security-scan (BusBuddy Security Analysis)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-Command", "bb-security-scan"],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "Trunk Check C# Files Only",
      "type": "shell",
      "command": "trunk",
      "args": ["check", "**/*.cs", "**/*.csproj"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Trunk Check PowerShell Files Only",
      "type": "shell",
      "command": "trunk",
      "args": ["check", "**/*.ps1", "**/*.psm1"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Trunk Check XAML Files Only",
      "type": "shell",
      "command": "trunk",
      "args": ["check", "**/*.xaml"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Trunk Format C# Files Only",
      "type": "shell",
      "command": "trunk",
      "args": ["fmt", "**/*.cs"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Trunk Format PowerShell Files Only",
      "type": "shell",
      "command": "trunk",
      "args": ["fmt", "**/*.ps1", "**/*.psm1"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Trunk Format XAML Files Only",
      "type": "shell",
      "command": "trunk",
      "args": ["fmt", "**/*.xaml"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Generate Fetchability Index",
      "type": "shell",
      "command": "pwsh",
      "args": ["-Command", "& './generate-fetchability-index.ps1' -Validate"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "PSScriptAnalyzer (PowerShell Quality)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-Command",
        "Invoke-ScriptAnalyzer -Path '${workspaceFolder}\\tools\\powershell' -Recurse -Settings '${workspaceFolder}\\tools\\powershell\\PSScriptAnalyzerSettings.psd1'"
      ],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "psscriptanalyzer",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(Error|Warning|Information):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },

    // === TESTING TASKS ===
    {
      "label": "dotnet test (All Tests)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "BusBuddy.sln",
        "--configuration",
        "Debug",
        "--logger",
        "trx",
        "--collect",
        "XPlat Code Coverage"
      ],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": ["$msCompile"]
    },

    // === AZURE & SQL TASKS ===
    {
      "label": "Azure PowerShell Login Check",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-Command",
        "if (Get-AzContext) { Write-Output '✅ Azure PowerShell authenticated' } else { Write-Output '❌ Run Connect-AzAccount to authenticate' }"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "bb-azure-sql-query (Azure SQL via PowerShell)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-Command", "bb-sql-test"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // === UTILITY TASKS ===
    {
      "label": "Clean All (dotnet clean + bin/obj)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "tools/clean-all.ps1"],
      "group": "build",
      "options": {
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "DOTNET_NOLOGO": "1"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "close": false
      },
      "problemMatcher": []
    },
    {
      "label": "Restore NuGet Packages",
      "type": "shell",
      "command": "dotnet",
      "args": ["restore", "BusBuddy.sln", "--force", "--no-cache"],
      "group": "build",
      "options": {
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "DOTNET_NOLOGO": "1"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "close": false
      },
      "problemMatcher": [],
      "runOptions": {
        "reevaluateOnRerun": true
      }
    },

    // === FAST TASK VARIANTS (NO PROFILE) ===
    {
      "label": "Fast Restore (No Profile)",
      "type": "process",
      "command": "dotnet",
      "args": ["restore", "BusBuddy.sln", "--verbosity", "minimal"],
      "group": "build",
      "options": {
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "DOTNET_NOLOGO": "1"
        }
      },
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Fast Build (No Profile)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "BusBuddy.sln",
        "--verbosity",
        "minimal",
        "--no-restore"
      ],
      "group": "build",
      "options": {
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "DOTNET_NOLOGO": "1"
        }
      },
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Fast Clean (No Profile)",
      "type": "process",
      "command": "dotnet",
      "args": ["clean", "BusBuddy.sln", "--verbosity", "minimal"],
      "group": "build",
      "options": {
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "DOTNET_NOLOGO": "1"
        }
      },
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // === SYNCFUSION WPF DEVELOPMENT TASKS ===
    {
      "type": "shell",
      "label": "Syncfusion: Check License",
      "command": "pwsh",
      "args": [
        "-Command",
        "if ($env:SYNCFUSION_LICENSE_KEY) { Write-Host '✅ Syncfusion license configured' -ForegroundColor Green } else { Write-Host '❌ SYNCFUSION_LICENSE_KEY not set' -ForegroundColor Red }"
      ]
    },
    {
      "label": "Syncfusion: Validate XAML Controls",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-Command",
        "Get-ChildItem -Path '${workspaceFolder}' -Filter '*.xaml' -Recurse | ForEach-Object { $content = Get-Content $_.FullName -Raw; if ($content -match 'syncfusion:') { Write-Host \"✅ Syncfusion controls found in $($_.Name)\" -ForegroundColor Green } else { Write-Host \"ℹ️ No Syncfusion controls in $($_.Name)\" -ForegroundColor Yellow } }"
      ],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Syncfusion: Format All XAML Files",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-Command",
        "Get-ChildItem -Path '${workspaceFolder}' -Filter '*.xaml' -Recurse | ForEach-Object { Write-Host \"Formatting $($_.Name)\" -ForegroundColor Cyan }"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Syncfusion: Generate Documentation",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-Command",
        "$syncfusionControls = @(); Get-ChildItem -Path '${workspaceFolder}' -Filter '*.xaml' -Recurse | ForEach-Object { $content = Get-Content $_.FullName -Raw; $matches = [regex]::Matches($content, 'syncfusion:([A-Za-z0-9]+)'); foreach ($match in $matches) { $syncfusionControls += $match.Groups[1].Value } }; $syncfusionControls | Sort-Object -Unique | ForEach-Object { Write-Host \"Syncfusion Control: $_\" -ForegroundColor Green }"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Document Viewer: Open Settings",
      "type": "shell",
      "command": "code",
      "args": [
        "--command",
        "workbench.action.openSettings",
        "@ext:syncfusioninc.document-viewer-vscode-extensions"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
