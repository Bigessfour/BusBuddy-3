{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    // === POWERSHELL DEBUGGING ===
    {
      "name": "PowerShell: Windows PowerShell",
      "type": "PowerShell",
      "request": "launch",
      "sessionName": "Windows PowerShell (x64)"
    },
    {
      "name": "PowerShell: BusBuddy Profile Debug",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}\\PowerShell\\Profiles\\Microsoft.PowerShell_profile_optimized.ps1",
      "args": [],
      "cwd": "${workspaceFolder}",
      "createTemporaryIntegratedConsole": false
    },

    // === .NET WPF DEBUGGING ===
    {
      "name": ".NET Core Launch (BusBuddy WPF)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "bb-build (dotnet build BusBuddy.sln)",
      "program": "${workspaceFolder}/BusBuddy.WPF/bin/Debug/net9.0-windows/BusBuddy.WPF.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "BUSBUDDY_DEBUG": "1",
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": ".NET Core Launch (BusBuddy WPF - Staging)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "bb-build (dotnet build BusBuddy.sln)",
      "program": "${workspaceFolder}/BusBuddy.WPF/bin/Debug/net9.0-windows/BusBuddy.WPF.exe",
      "args": ["--environment", "Staging"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "BUSBUDDY_DEBUG": "1",
        "ASPNETCORE_ENVIRONMENT": "Staging"
      }
    },

    // === ATTACH TO RUNNING PROCESS ===
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    },

    // === TESTING DEBUGGING ===
    {
      "name": ".NET Core Launch (Tests)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet test (All Tests)",
      "program": "${workspaceFolder}/BusBuddy.Tests/bin/Debug/net9.0/BusBuddy.Tests.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "BUSBUDDY_TEST_MODE": "1"
      }
    },
    {
      "name": "bb-test (PowerShell-Integrated Tests)",
      "type": "PowerShell",
      "request": "launch",
      "script": "bb-test", // Profile alias for dotnet test
      "cwd": "${workspaceFolder}"
    },

    // === AZURE & SQL DEBUGGING ===
    {
      "name": "PowerShell: Azure SQL Test",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}\\Scripts\\Test-AzureSqlConnection.ps1",
      "args": [],
      "cwd": "${workspaceFolder}"
    },

    // === SYNCFUSION WPF XAML DEBUGGING ===
    {
      "name": "Syncfusion WPF Debug (XAML Live Preview)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Syncfusion: Check License",
      "program": "${workspaceFolder}/BusBuddy.WPF/bin/Debug/net9.0-windows/BusBuddy.WPF.exe",
      "args": ["--syncfusion-debug", "--xaml-hot-reload"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "BUSBUDDY_DEBUG": "1",
        "SYNCFUSION_DEBUG": "1",
        "XAML_HOT_RELOAD": "1",
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views/": "${workspaceFolder}/BusBuddy.WPF/Views/",
        "/Controls/": "${workspaceFolder}/BusBuddy.WPF/Controls/"
      }
    },
    {
      "name": "Document Viewer Debug",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/BusBuddy.WPF/bin/Debug/net9.0-windows/BusBuddy.WPF.exe",
      "args": ["--document-viewer-debug"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "DOCUMENT_VIEWER_DEBUG": "1",
        "SYNCFUSION_DOCUMENT_FEATURES": "all"
      }
    },

    // === OPENSILVER DEBUGGING ===
    {
      "name": "OpenSilver: Debug Browser Application",
      "type": "blazorwasm",
      "request": "launch",
      "hosted": true,
      "program": "${workspaceFolder}/*/bin/Debug/net*/BusBuddy.Browser.exe",
      "preLaunchTask": "bb-build (dotnet build BusBuddy.sln)",
      "url": "https://localhost:5001",
      "webRoot": "${workspaceFolder}/**/wwwroot",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
      }
    },
    {
      "name": "OpenSilver: Debug Simulator",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/*/bin/Debug/net*/BusBuddy.Simulator.exe",
      "preLaunchTask": "bb-build (dotnet build BusBuddy.sln)",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "OPENSILVER_DEBUG": "1"
      }
    },
    {
      "name": "OpenSilver: Attach to Browser Process",
      "type": "blazorwasm",
      "request": "attach",
      "url": "https://localhost:5001"
    }
  ],
  "compounds": [
    {
      "name": "Launch BusBuddy with Health Check",
      "configurations": [".NET Core Launch (BusBuddy WPF)"]
    }
  ]
}
