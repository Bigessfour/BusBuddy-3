    "COPILOT_MODEL_OVERRIDE": "gpt-5",
    "COPILOT_FALLBACK_MODEL": "gpt-5-mini",
    "MCP_DOCS_PORT": "5151",
    "MCP_DOCS_ENABLED": "true",
    "MCP_FILESYSTEM_PATH": "c:\\Users\\biges\\Desktop\\BusBuddy",
    // Load environment variables from .env file
    "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}",
    "GITHUB_API_URL": "https://api.github.com",
    "BRAVE_API_KEY": "${env:BRAVE_API_KEY}",
    "XAI_API_KEY": "${env:XAI_API_KEY}",
    "SYNCFUSION_LICENSE_KEY": "${env:SYNCFUSION_LICENSE_KEY}"
  },
  "trunk.enableLinting": true,
  "trunk.enableFormatting": true,
  "trunk.formatOnSave": true,
  "trunk.gitIntegration": true,
  "trunk.showStatusInExplorer": true,
  "trunk.autoFormatOnPaste": true,
  "trunk.enableActions": true,
  "trunk.inlineDecorators": true,
  "trunk.inlineDecoratorsForAllExtensions": true,
  "trunk.formatOnSaveTimeout": 5000,
  "trunk.lintOnSaveTimeout": 10000,
  "trunk.checkOnSaveTimeout": 15000,
  "dotnet-test-explorer.testProjectPath": "**/*.Tests.csproj",
  "dotnet-test-explorer.testArguments": "--configuration Debug --logger trx",
  "dotnet-test-explorer.testSettingsPath": "${workspaceFolder}/testsettings.runsettings",
  "dotnet-test-explorer.enableTelemetry": false,
  "dotnet-test-explorer.showCodeCoverage": true,
  "dotnet-test-explorer.codeCoverageTool": "coverlet",
  "dotnet-test-explorer.runInParallel": false,
  "dotnet-test-explorer.autoWatch": true,
  "dotnet-test-explorer.addProblems": true,
  "nunitTestExplorer.testProjectPath": "**/*.Tests.csproj",
  "nunitTestExplorer.testArguments": "--configuration Debug --logger trx",
  "nunitTestExplorer.testSettingsPath": "${workspaceFolder}/testsettings.runsettings",
  "nunitTestExplorer.enableTelemetry": false,
  "nunitTestExplorer.showCodeCoverage": true,
  "nunitTestExplorer.codeCoverageTool": "coverlet",
  "nunitTestExplorer.runInParallel": false,
  "nunitTestExplorer.autoWatch": true,
  "nunitTestExplorer.addProblems": true,
  "nunitTestExplorer.dotNetCliPaths": ["dotnet"],
  "editor.defaultFormatter": "trunk.io",
  "editor.snippets.codeLens": true,
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.formatOnType": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.trimAutoWhitespace": true,
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 120,
    "editor.rulers": [80, 120],
    "editor.suggest.showKeywords": true,
    "editor.suggest.showSnippets": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "files.encoding": "utf8bom",
    "files.autoGuessEncoding": true,
    "files.trimTrailingWhitespace": true,
    "editor.renderWhitespace": "boundary",
    "editor.renderControlCharacters": true
  },
  "[csharp]": {
    "editor.defaultFormatter": "trunk.io"
  },
  "csharp.suppressDotnetRestoreNotification": true,
  "dotnetAcquisitionExtension.existingDotnetPath": [
    {
      "extensionId": "ms-dotnettools.csharp",
      "path": "C:\\Program Files\\dotnet\\dotnet.exe"
    },
    {
      "extensionId": "ms-dotnettools.csdevkit",
      "path": "C:\\Program Files\\dotnet\\dotnet.exe"
    },
    {
      "extensionId": "ms-dotnettools.vscode-dotnet-runtime",
      "path": "C:\\Program Files\\dotnet\\dotnet.exe"
    }
  ],
  "omnisharp.enableRoslynAnalyzers": true,
  "omnisharp.enableEditorConfigSupport": true,
  "dotnet.completion.showCompletionItemsFromUnimportedNamespaces": true,
  "dotnet.inlayHints.enableInlayHintsForParameters": true,
  "dotnet.inlayHints.enableInlayHintsForLiteralParameters": true,
  "dotnet.inlayHints.enableInlayHintsForIndexerParameters": true,
  "dotnet.inlayHints.enableInlayHintsForObjectCreationParameters": true,
  "dotnet.inlayHints.enableInlayHintsForOtherParameters": true,
  "dotnet.inlayHints.suppressInlayHintsForParametersThatDifferOnlyBySuffix": true,
  "dotnet.inlayHints.suppressInlayHintsForParametersThatMatchMethodIntent": true,
  "dotnet.inlayHints.suppressInlayHintsForParametersThatMatchArgumentName": true,
  "roslynator.enableAnalyzersSupport": true,
  "roslynator.enableRefactoringsSupport": true,
  "roslynator.enableCodeFixesSupport": true,
  "roslynator.suppressUnityScriptMethods": false,
  "[xaml]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "trunk.io",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 120,
    "editor.rulers": [80, 120],
    "editor.suggest.showKeywords": true,
    "editor.suggest.showSnippets": true,
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    }
  },
  "xml.format.enabled": true,
  "xaml.completion.snippets": true,
  "xaml.format.enable": true,
  "xaml.format.keepFirstAttributeOnSameLine": false,
  "xaml.format.maxAttributesPerLine": 1,
  "xaml.format.putEndingBracketOnNewLine": true,

  // Syncfusion WPF XAML Configuration for BusBuddy
  "xml.completion.enabled": true,
  "xml.validation.enabled": true,
  "xml.format.splitAttributes": "splitNewLine",
  "xml.format.joinContentLines": false,
  "xml.format.preserveWhitespace": ["text", "comment"],
  "xml.documentSymbols.enabled": true,
  "xml.folding.includeClosingTagInFold": false,

  // Enhanced XAML Editing for Syncfusion WPF
  "xmlTools.enableXmlTreeView": true,
  "xmlTools.enableXmlFormatterV2": true,
  "xmlTools.formatAsXmlOnSave": true,

  // Syncfusion CLI Integration
  "syncfusion.cli.enabled": true,
  "syncfusion.cli.scriptPath": "${workspaceFolder}/syncfusion-cli.ps1",
  "syncfusion.cli.autoValidate": true,
  "syncfusion.cli.showLicenseWarning": true,

  // Syncfusion Document Viewer Configuration
  "documentViewer.enablePreview": true,
  "documentViewer.previewFormats": ["pdf", "docx", "xlsx", "md"],
  "documentViewer.autoOpen": true,
  "documentViewer.showThumbnails": true,
  "documentViewer.enableSearch": true,
  "documentViewer.enableAnnotations": true,
  "documentViewer.enableBookmarks": true,
  "documentViewer.enablePrint": true,
  "documentViewer.enableExport": true,
  "documentViewer.zoomLevel": "fitToPage",
  "documentViewer.theme": "dark",
  "documentViewer.enableTextSelection": true,
  "documentViewer.enableHyperlinks": true,
  "documentViewer.enableFormFilling": true,

  // WPF and XAML IntelliSense
  "xaml.completion.enabled": true,
  "xaml.validation.enabled": true,
  "xaml.format.enabled": true,
  "xaml.intellisense.enabled": true,
  "xaml.designer.enabled": true,
  "xaml.preview.enabled": true,
  "xaml.syncfusion.namespaces": [
