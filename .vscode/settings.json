    "clr-namespace:Syncfusion.UI.Xaml.Grid;assembly=Syncfusion.SfGrid.WPF",
    "clr-namespace:Syncfusion.UI.Xaml.Controls.Input;assembly=Syncfusion.SfInput.WPF",
    "clr-namespace:Syncfusion.UI.Xaml.Charts;assembly=Syncfusion.SfChart.WPF"
