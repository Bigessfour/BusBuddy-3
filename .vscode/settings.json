  // === GitHub Copilot (GPT-5 mini) Configuration ===
  "github.copilot": {
    "enable": {
      "csharp": true,
      "powershell": true,
      "json": true,
      "xml": true,
      "xaml": true
    },
    "editor": {
      "enableAutoCompletions": true,
      "iterativeFixing": true,
      "enableInlineCompletions": true,
      "suggest": {
        "localityBonus": true
      },
      "wordWrap": "wordWrapColumn",
      "wordWrapColumn": 120,
      "rulers": [80, 120],
      "inlineSuggest": {
        "count": 5,
        "delay": 200
      }
    },
    "advanced": {
      "length": 800,
      "temperature": 0.1,
      "top_p": 0.85,
      "telemetry": false,
      "inlineSuggestCount": 5
    },
    "suggestionPriorities": {
      "csharp": {
        "priorityPatterns": [
          "Syncfusion",
          "SfDataGrid",
          "Syncfusion.UI.Xaml.Grid",
          "syncfusion:SfDataGrid"
        ],
        "preferSnippets": true
      },
      "xaml": {
        "priorityPatterns": [
          "syncfusion:SfDataGrid",
          "xmlns:syncfusion",
          "GridTextColumn",
          "GridNumericColumn"
        ],
        "preferSnippets": true
      }
    },
    "rules": {
      "csharp": {
        "preferNamespaces": [
          "Syncfusion.UI.Xaml.Grid",
          "Syncfusion",
          "Microsoft.EntityFrameworkCore", // Prefer EF Core for Azure SQL models
          "Serilog" // Prefer Serilog for structured logging
        ]
      },
      "xaml": {
        "preferNamespacePrefixes": ["syncfusion"],
        "preferredElementPatterns": [
          "syncfusion:SfDataGrid",
          "syncfusion:GridTextColumn"
        ]
      },
      "powershell": {
        "preferCommands": [
          "sqlcmd", // Align with BusBuddy policy: use sqlcmd for Azure SQL querying
          "az" // Allow Azure CLI usage where appropriate
        ]
      }
    },
    "compatibility": {
      "respectWorkspaceEnv": true,
      "preserveSettings": [
        "azure.*",
        "powershell.*",
        "trunk.*",
        "taskExplorer.*"
      ]
    },
    "modelOverride": "gpt-5",
    "fallbackModel": "gpt-5-mini"
  },
