# BusBuddy Google Cloud / Earth Engine local config (non-secret)
# Generated 2026-06-15 via gcloud setup. Do not commit keys/.

export PATH="/opt/homebrew/share/google-cloud-sdk/bin:/opt/homebrew/bin:$PATH"

# Primary GCP console project (billing / general)
export GCP_BILLING_PROJECT="new-coursera-490518"

# Production: App loads these from macOS Passwords on startup (store-gcp-passwords.sh)
# Dev shell: source this file before dotnet run
export GEE_PROJECT_ID="ee-bigessfour"
export GEE_SERVICE_ACCOUNT_EMAIL="bus-buddy-gee@ee-bigessfour.iam.gserviceaccount.com"
export GCP_BILLING_PROJECT="new-coursera-490518"
export GOOGLE_CLOUD_PROJECT="new-coursera-490518"
export GOOGLE_APPLICATION_CREDENTIALS="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)/keys/bus-buddy-gee-key.json"

gcloud config set project "$GCP_BILLING_PROJECT" 2>/dev/null || true
