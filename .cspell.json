{
  "version": "0.2",
  "language": "en-US",
  "allowCompoundWords": true,
  "dictionaries": ["en-US", "project-dictionary", "spelling-exclusions"],
  "dictionaryDefinitions": [
    {
      "name": "project-dictionary",
      "path": "./project-dictionary.txt",
      "description": "BusBuddy project-specific terms and technical vocabulary"
    },
    {
      "name": "spelling-exclusions",
      "path": "./spelling-exclusions.dic",
      "description": "Words to exclude from spell checking"
    }
  ],
  "ignoreWords": [
    "BAANKCL",
    "SEEDLIC",
    "SEEDVIN",
    "DBATOOLS",
    "MODULEINFO",
    "PSSCRIPTANALYZER",
    "tojson",
    "nunit",
    "OTBS",
    "Fira",
    "Exif",
    "cref"
  ],
  "languageSettings": [
    {
      "languageId": "*",
      "allowCompoundWords": true
    }
  ],
  "overrides": [
    {
      "filename": "**/*.cs",
      "allowCompoundWords": true
    },
    {
      "filename": "**/*.ps1",
      "allowCompoundWords": true
    },
    {
      "filename": "**/*.psm1",
      "allowCompoundWords": true
    },
    {
      "filename": "**/*.xaml",
      "allowCompoundWords": true
    },
    {
      "filename": "**/*.json",
      "allowCompoundWords": true
    },
    {
      "filename": "**/*.yaml",
      "allowCompoundWords": true
    },
    {
      "filename": "**/*.yml",
      "allowCompoundWords": true
    }
  ],
  "ignorePaths": [
    "**/bin/**",
    "**/obj/**",
    "**/TestResults/**",
    "**/.trunk/**",
    "**/node_modules/**",
    "**/packages/**",
    "**/*.log",
    "**/*.tmp",
    "**/BusBuddy.db*",
    "**/appsettings.*.json",
    "**/*.user",
    "**/*.suo",
    "**/.vs/**"
  ]
}
